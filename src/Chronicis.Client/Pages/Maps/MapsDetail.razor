@page "/world/{WorldId:guid}/maps"
@attribute [Authorize]
@implements IAsyncDisposable
@using Chronicis.Client.Components.Shared
@using Chronicis.Shared.DTOs
@using Chronicis.Shared.DTOs.Maps
@using Chronicis.Shared.Enums
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IMapApiService MapApi
@inject IWorldApiService WorldApi
@inject IArcApiService ArcApi
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject ITreeStateService TreeState
@inject NavigationManager Navigation

@if (_isLoading)
{
    <LoadingSkeleton />
}
else if (_hasLoadFailure)
{
    <MudAlert Severity="Severity.Error">
        World not found or access denied.
    </MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="chronicis-article-card chronicis-fade-in">
        <DetailPageHeader Breadcrumbs="_breadcrumbs"
                          Icon="@Icons.Material.Filled.Map"
                          Title="@_mapsTitle"
                          Placeholder="Maps"
                          ReadOnly="true" />

        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
            Maps grouped by world, campaign, and arc scope.
        </MudText>

        <MudPaper Outlined="true" Class="pa-4 mb-4 maps-create-card">
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.AddPhotoAlternate" Size="Size.Small" Class="mr-2" />
                Create map
            </MudText>
            <MudStack Spacing="2">
                <MudTextField @bind-Value="_newMapName"
                              Label="Map name"
                              Variant="Variant.Outlined"
                              Required="true"
                              Disabled="_isCreatingMap" />

                <div class="@GetBasemapDropZoneClass()"
                     style="position: relative;"
                     @ondragenter="OnBasemapDragEnter"
                     @ondragenter:preventDefault="true"
                     @ondragleave="OnBasemapDragLeave"
                     @ondragover="OnBasemapDragOver"
                     @ondragover:preventDefault="true"
                     @ondragover:stopPropagation="true"
                     @ondrop="OnBasemapDrop"
                     @ondrop:stopPropagation="true">
                    <InputFile id="mapBasemapFileInput"
                               OnChange="OnBasemapFileSelected"
                               accept="image/png,image/jpeg,image/webp"
                               disabled="@_isCreatingMap"
                               style="@GetBasemapInputStyle()"
                               class="maps-basemap-dropzone__input" />
                    <label for="mapBasemapFileInput" class="maps-basemap-dropzone__label">
                        <MudIcon Icon="@Icons.Material.Filled.UploadFile" Size="Size.Large" Class="mb-2" />
                        <MudText Typo="Typo.body1" Class="maps-basemap-dropzone__title">
                            @(_selectedBasemapFile == null ? "Choose basemap image" : _selectedBasemapFile.Name)
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Click to browse or drag an image file here
                        </MudText>
                    </label>
                </div>

                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Supported types: image/png, image/jpeg, image/webp
                </MudText>

                @if (!string.IsNullOrWhiteSpace(_createError))
                {
                    <MudAlert Severity="Severity.Error">@_createError</MudAlert>
                }

                @if (!string.IsNullOrWhiteSpace(_createSuccess))
                {
                    <MudAlert Severity="Severity.Success">@_createSuccess</MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="CreateMapWithBasemapAsync"
                           Disabled="_isCreatingMap">
                    @(_isCreatingMap ? "Uploading..." : "Create map")
                </MudButton>
            </MudStack>
        </MudPaper>

        @if (!_maps.Any())
        {
            <MudAlert Severity="Severity.Info">
                No maps found for this world.
            </MudAlert>
        }
        else
        {
            @if (_worldScopedMaps.Any())
            {
                <MudPaper Outlined="true" Class="pa-4 mb-4 maps-scope-card">
                    <MudText Typo="Typo.h6" Class="mb-2 maps-scope-title">
                        <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" Class="mr-2" />
                        World-scoped
                    </MudText>
                    <MudList T="MapSummaryDto" Dense="true">
                        @foreach (var map in _worldScopedMaps)
                        {
                            <EntityListItem Icon="@Icons.Material.Filled.Map"
                                            Title="@GetDisplayName(map.Name, "Untitled Map")"
                                            Href="@GetMapRoute(map.WorldMapId)">
                                <span @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenDeleteDialogAsync(map))"
                                                   Disabled="@IsDeleteInProgress(map.WorldMapId)" />
                                </span>
                            </EntityListItem>
                        }
                    </MudList>
                </MudPaper>
            }

            @if (_campaignScopedGroups.Any())
            {
                <MudPaper Outlined="true" Class="pa-4 mb-4 maps-scope-card">
                    <MudText Typo="Typo.h6" Class="mb-2 maps-scope-title">
                        <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Small" Class="mr-2" />
                        Campaign-scoped
                    </MudText>
                    @foreach (var campaignGroup in _campaignScopedGroups)
                    {
                        <div class="maps-group-block">
                            <MudText Typo="Typo.subtitle1" Class="mb-1 maps-group-heading">
                                @campaignGroup.CampaignName
                            </MudText>
                            <MudList T="MapSummaryDto" Dense="true">
                                @foreach (var map in campaignGroup.Maps)
                                {
                                    <EntityListItem Icon="@Icons.Material.Filled.Map"
                                                    Title="@GetDisplayName(map.Name, "Untitled Map")"
                                                    Href="@GetMapRoute(map.WorldMapId)">
                                        <span @onclick:stopPropagation="true">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => OpenDeleteDialogAsync(map))"
                                                           Disabled="@IsDeleteInProgress(map.WorldMapId)" />
                                        </span>
                                    </EntityListItem>
                                }
                            </MudList>
                        </div>
                    }
                </MudPaper>
            }

            @if (_arcScopedCampaignGroups.Any())
            {
                <MudPaper Outlined="true" Class="pa-4 maps-scope-card">
                    <MudText Typo="Typo.h6" Class="mb-2 maps-scope-title">
                        <MudIcon Icon="@Icons.Material.Filled.Bookmark" Size="Size.Small" Class="mr-2" />
                        Arc-scoped
                    </MudText>
                    @foreach (var campaignGroup in _arcScopedCampaignGroups)
                    {
                        <div class="maps-group-block">
                            <MudText Typo="Typo.subtitle1" Class="mb-1 maps-group-heading">
                                @campaignGroup.CampaignName
                            </MudText>
                            @foreach (var arcGroup in campaignGroup.ArcGroups)
                            {
                                <MudText Typo="Typo.subtitle2" Class="mb-1 maps-arc-heading">
                                    @arcGroup.ArcName
                                </MudText>
                                <MudList T="MapSummaryDto" Dense="true">
                                    @foreach (var map in arcGroup.Maps)
                                    {
                                        <EntityListItem Icon="@Icons.Material.Filled.Map"
                                                        Title="@GetDisplayName(map.Name, "Untitled Map")"
                                                        Href="@GetMapRoute(map.WorldMapId)">
                                            <span @onclick:stopPropagation="true">
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Color="Color.Error"
                                                               Size="Size.Small"
                                                               OnClick="@(() => OpenDeleteDialogAsync(map))"
                                                               Disabled="@IsDeleteInProgress(map.WorldMapId)" />
                                            </span>
                                        </EntityListItem>
                                    }
                                </MudList>
                            }
                        </div>
                    }
                </MudPaper>
            }
        }
    </MudPaper>
}

@code {
    private static readonly DialogOptions _deleteDialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
    };

    [Parameter]
    public Guid WorldId { get; set; }

    private bool _isLoading = true;
    private bool _hasLoadFailure;
    private string _worldName = "World";
    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/dashboard"),
        new("World", href: null, disabled: true),
        new("Maps", href: null, disabled: true)
    ];
    private List<MapSummaryDto> _maps = [];
    private List<MapSummaryDto> _worldScopedMaps = [];
    private List<CampaignMapGroup> _campaignScopedGroups = [];
    private List<ArcCampaignGroup> _arcScopedCampaignGroups = [];
    private string _newMapName = string.Empty;
    private IBrowserFile? _selectedBasemapFile;
    private byte[]? _selectedBasemapBytes;
    private bool _isBasemapDragOver;
    private bool _isCreatingMap;
    private bool _isDropGuardEnabled;
    private readonly HashSet<Guid> _mapsBeingDeleted = [];
    private string _createError = string.Empty;
    private string _createSuccess = string.Empty;
    private string _mapsTitle => $"{_worldName} Maps";

    private const long MaxBasemapSizeBytes = 50 * 1024 * 1024;
    private static readonly HashSet<string> AllowedBasemapContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "image/png",
        "image/jpeg",
        "image/webp"
    };

    private sealed class CampaignMapGroup
    {
        public Guid CampaignId { get; init; }
        public string CampaignName { get; init; } = string.Empty;
        public List<MapSummaryDto> Maps { get; init; } = [];
    }

    private sealed class ArcMapGroup
    {
        public Guid ArcId { get; init; }
        public string ArcName { get; init; } = string.Empty;
        public List<MapSummaryDto> Maps { get; init; } = [];
    }

    private sealed class ArcCampaignGroup
    {
        public Guid CampaignId { get; init; }
        public string CampaignName { get; init; } = string.Empty;
        public List<ArcMapGroup> ArcGroups { get; init; } = [];
    }

    private sealed class ArcLookupItem
    {
        public Guid CampaignId { get; init; }
        public string ArcName { get; init; } = string.Empty;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("chronicisMapsDropGuard.enable", ".maps-basemap-dropzone");
            _isDropGuardEnabled = true;
        }
        catch (JSDisconnectedException)
        {
            // Navigation/disposal race; ignore.
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _hasLoadFailure = false;
        _maps = [];
        _worldScopedMaps = [];
        _campaignScopedGroups = [];
        _arcScopedCampaignGroups = [];
        _breadcrumbs =
        [
            new("Dashboard", href: "/dashboard"),
            new("World", href: null, disabled: true),
            new("Maps", href: null, disabled: true)
        ];

        try
        {
            var world = await WorldApi.GetWorldAsync(WorldId);
            if (world == null)
            {
                _hasLoadFailure = true;
                return;
            }

            _worldName = GetDisplayName(world.Name, "World");
            _breadcrumbs =
            [
                new("Dashboard", href: "/dashboard"),
                new(_worldName, href: $"/world/{WorldId}"),
                new("Maps", href: null, disabled: true)
            ];

            await SyncTreeSelectionAsync();

            _maps = await MapApi.ListMapsForWorldAsync(WorldId);

            var campaignLookup = world.Campaigns
                .GroupBy(c => c.Id)
                .ToDictionary(
                    g => g.Key,
                    g => GetDisplayName(g.First().Name, "Untitled Campaign"));

            var arcLookup = await BuildArcLookupAsync(campaignLookup.Keys.ToList());

            BuildGroupings(campaignLookup, arcLookup);
        }
        catch
        {
            _hasLoadFailure = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnBasemapFileSelected(InputFileChangeEventArgs e)
    {
        _isBasemapDragOver = false;
        _createError = string.Empty;
        _createSuccess = string.Empty;
        _selectedBasemapFile = e.File;
        _selectedBasemapBytes = null;

        if (_selectedBasemapFile == null)
        {
            return;
        }

        if (!AllowedBasemapContentTypes.Contains(_selectedBasemapFile.ContentType))
        {
            _createError = "Unsupported file type. Use image/png, image/jpeg, or image/webp.";
            _selectedBasemapFile = null;
            return;
        }

        try
        {
            using var stream = _selectedBasemapFile.OpenReadStream(MaxBasemapSizeBytes);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            _selectedBasemapBytes = memoryStream.ToArray();
        }
        catch (Exception ex)
        {
            _createError = $"Failed to read selected file: {ex.Message}";
            _selectedBasemapFile = null;
            _selectedBasemapBytes = null;
        }
    }

    private void OnBasemapDragEnter(DragEventArgs e)
    {
        if (_isCreatingMap)
        {
            return;
        }

        _isBasemapDragOver = IsFileDragEvent(e);
        if (_isBasemapDragOver && e.DataTransfer != null)
        {
            e.DataTransfer.DropEffect = "copy";
            e.DataTransfer.EffectAllowed = "copy";
        }
    }

    private void OnBasemapDragOver(DragEventArgs e)
    {
        if (_isCreatingMap)
        {
            return;
        }

        _isBasemapDragOver = IsFileDragEvent(e);
        if (_isBasemapDragOver && e.DataTransfer != null)
        {
            e.DataTransfer.DropEffect = "copy";
            e.DataTransfer.EffectAllowed = "copy";
        }
    }

    private void OnBasemapDragLeave(DragEventArgs _)
    {
        _isBasemapDragOver = false;
    }

    private void OnBasemapDrop(DragEventArgs _)
    {
        _isBasemapDragOver = false;
    }

    private string GetBasemapDropZoneClass()
    {
        var classes = new List<string> { "maps-basemap-dropzone" };
        if (_isBasemapDragOver)
        {
            classes.Add("maps-basemap-dropzone--dragover");
            classes.Add("maps-basemap-dropzone--copy");
        }

        if (_isCreatingMap)
        {
            classes.Add("maps-basemap-dropzone--disabled");
        }

        return string.Join(" ", classes);
    }

    private string GetBasemapInputStyle()
        => $"position:absolute;inset:0;width:100%;height:100%;opacity:0;cursor:{(_isBasemapDragOver ? "copy" : "pointer")};z-index:2;";

    private static bool IsFileDragEvent(DragEventArgs e)
    {
        var dataTransfer = e.DataTransfer;
        if (dataTransfer == null)
        {
            return false;
        }

        if (dataTransfer.Files != null && dataTransfer.Files.Length > 0)
        {
            return true;
        }

        if (dataTransfer.Types == null)
        {
            return false;
        }

        foreach (var dataType in dataTransfer.Types)
        {
            if (string.Equals(dataType, "Files", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    public async ValueTask DisposeAsync()
    {
        if (!_isDropGuardEnabled)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("chronicisMapsDropGuard.disable");
        }
        catch (JSDisconnectedException)
        {
            // Browser disconnected; nothing to clean up.
        }
    }

    private async Task OpenDeleteDialogAsync(MapSummaryDto map)
    {
        var mapName = GetDisplayName(map.Name, "Untitled Map");

        if (IsDeleteInProgress(map.WorldMapId))
        {
            return;
        }

        var parameters = new DialogParameters<DeleteMapDialog>
        {
            { x => x.MapName, mapName }
        };

        var dialog = await DialogService.ShowAsync<DeleteMapDialog>(
            $"Delete \"{mapName}\"",
            parameters,
            _deleteDialogOptions);

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await DeleteMapAsync(map.WorldMapId, mapName);
        }
    }

    private async Task DeleteMapAsync(Guid mapId, string mapName)
    {
        _createError = string.Empty;
        _createSuccess = string.Empty;
        _mapsBeingDeleted.Add(mapId);

        try
        {
            var deleted = await MapApi.DeleteMapAsync(WorldId, mapId);
            if (!deleted)
            {
                _createError = $"Failed to delete map '{mapName}'.";
                return;
            }

            _createSuccess = $"Map '{mapName}' deleted permanently.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _createError = $"Failed to delete map '{mapName}': {ex.Message}";
        }
        finally
        {
            _mapsBeingDeleted.Remove(mapId);
        }
    }

    private bool IsDeleteInProgress(Guid mapId) => _mapsBeingDeleted.Contains(mapId);

    private async Task CreateMapWithBasemapAsync()
    {
        _createError = string.Empty;
        _createSuccess = string.Empty;

        if (string.IsNullOrWhiteSpace(_newMapName))
        {
            _createError = "Map name is required.";
            return;
        }

        if (_selectedBasemapFile == null || _selectedBasemapBytes == null)
        {
            _createError = "Basemap file is required.";
            return;
        }

        if (!AllowedBasemapContentTypes.Contains(_selectedBasemapFile.ContentType))
        {
            _createError = "Unsupported file type. Use image/png, image/jpeg, or image/webp.";
            return;
        }

        _isCreatingMap = true;

        try
        {
            var map = await MapApi.CreateMapAsync(
                WorldId,
                new MapCreateDto { Name = _newMapName.Trim() });

            if (map == null)
            {
                _createError = "Failed to create map record.";
                return;
            }

            var uploadRequest = new RequestBasemapUploadDto
            {
                FileName = _selectedBasemapFile.Name,
                ContentType = _selectedBasemapFile.ContentType
            };

            var uploadResponse = await MapApi.RequestBasemapUploadAsync(WorldId, map.WorldMapId, uploadRequest);
            if (uploadResponse == null || string.IsNullOrWhiteSpace(uploadResponse.UploadUrl))
            {
                _createError = "Failed to request basemap upload URL.";
                return;
            }

            using (var uploadContent = new ByteArrayContent(_selectedBasemapBytes))
            {
                uploadContent.Headers.ContentType =
                    new System.Net.Http.Headers.MediaTypeHeaderValue(_selectedBasemapFile.ContentType);
                uploadContent.Headers.Add("x-ms-blob-type", "BlockBlob");

                using var uploadHttpClient = new HttpClient { Timeout = TimeSpan.FromMinutes(5) };
                var uploadResult = await uploadHttpClient.PutAsync(uploadResponse.UploadUrl, uploadContent);
                if (!uploadResult.IsSuccessStatusCode)
                {
                    var errorBody = await uploadResult.Content.ReadAsStringAsync();
                    _createError = $"Basemap upload failed ({uploadResult.StatusCode}): {errorBody}";
                    return;
                }
            }

            var confirmResult = await MapApi.ConfirmBasemapUploadAsync(
                WorldId,
                map.WorldMapId,
                $"maps/{map.WorldMapId}/basemap/{_selectedBasemapFile.Name}",
                _selectedBasemapFile.ContentType,
                _selectedBasemapFile.Name);

            if (confirmResult == null)
            {
                _createError = "Failed to confirm basemap upload.";
                return;
            }

            _createSuccess = $"Map '{confirmResult.Name}' created.";
            _newMapName = string.Empty;
            _selectedBasemapFile = null;
            _selectedBasemapBytes = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _createError = $"Failed to create map: {ex.Message}";
        }
        finally
        {
            _isCreatingMap = false;
        }
    }

    private async Task<Dictionary<Guid, ArcLookupItem>> BuildArcLookupAsync(List<Guid> campaignIds)
    {
        var lookup = new Dictionary<Guid, ArcLookupItem>();
        var distinctCampaignIds = campaignIds.Distinct().ToList();

        if (distinctCampaignIds.Count == 0)
        {
            return lookup;
        }

        var arcTasks = distinctCampaignIds
            .Select(campaignId => ArcApi.GetArcsByCampaignAsync(campaignId))
            .ToList();

        await Task.WhenAll(arcTasks);

        for (int i = 0; i < distinctCampaignIds.Count; i++)
        {
            var campaignId = distinctCampaignIds[i];
            var arcs = arcTasks[i].Result;

            foreach (var arc in arcs)
            {
                if (!lookup.ContainsKey(arc.Id))
                {
                    lookup[arc.Id] = new ArcLookupItem
                    {
                        CampaignId = campaignId,
                        ArcName = GetDisplayName(arc.Name, "Untitled Arc")
                    };
                }
            }
        }

        return lookup;
    }

    private void BuildGroupings(
        Dictionary<Guid, string> campaignLookup,
        Dictionary<Guid, ArcLookupItem> arcLookup)
    {
        _worldScopedMaps = _maps
            .Where(map => ResolveScope(map) == MapScope.WorldScoped)
            .OrderBy(map => map.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(map => map.WorldMapId)
            .ToList();

        _campaignScopedGroups = _maps
            .Where(map => ResolveScope(map) == MapScope.CampaignScoped)
            .SelectMany(map => map.CampaignIds.Distinct().Select(campaignId => new { campaignId, map }))
            .GroupBy(x => x.campaignId)
            .Select(group => new CampaignMapGroup
            {
                CampaignId = group.Key,
                CampaignName = campaignLookup.TryGetValue(group.Key, out var campaignName)
                    ? campaignName
                    : $"Unknown Campaign ({group.Key})",
                Maps = group
                    .Select(x => x.map)
                    .DistinctBy(x => x.WorldMapId)
                    .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(x => x.WorldMapId)
                    .ToList()
            })
            .OrderBy(group => group.CampaignName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.CampaignId)
            .ToList();

        _arcScopedCampaignGroups = _maps
            .Where(map => ResolveScope(map) == MapScope.ArcScoped)
            .SelectMany(map => map.ArcIds.Distinct().Select(arcId =>
            {
                if (arcLookup.TryGetValue(arcId, out var arc))
                {
                    var campaignName = campaignLookup.TryGetValue(arc.CampaignId, out var name)
                        ? name
                        : $"Unknown Campaign ({arc.CampaignId})";

                    return new
                    {
                        CampaignId = arc.CampaignId,
                        CampaignName = campaignName,
                        ArcId = arcId,
                        ArcName = arc.ArcName,
                        Map = map
                    };
                }

                return new
                {
                    CampaignId = Guid.Empty,
                    CampaignName = "Unknown Campaign",
                    ArcId = arcId,
                    ArcName = $"Unknown Arc ({arcId})",
                    Map = map
                };
            }))
            .GroupBy(x => new { x.CampaignId, x.CampaignName })
            .Select(campaignGroup => new ArcCampaignGroup
            {
                CampaignId = campaignGroup.Key.CampaignId,
                CampaignName = campaignGroup.Key.CampaignName,
                ArcGroups = campaignGroup
                    .GroupBy(x => new { x.ArcId, x.ArcName })
                    .Select(arcGroup => new ArcMapGroup
                    {
                        ArcId = arcGroup.Key.ArcId,
                        ArcName = arcGroup.Key.ArcName,
                        Maps = arcGroup
                            .Select(x => x.Map)
                            .DistinctBy(x => x.WorldMapId)
                            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                            .ThenBy(x => x.WorldMapId)
                            .ToList()
                    })
                    .OrderBy(group => group.ArcName, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(group => group.ArcId)
                    .ToList()
            })
            .OrderBy(group => group.CampaignName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(group => group.CampaignId)
            .ToList();
    }

    private static MapScope ResolveScope(MapSummaryDto map)
    {
        var derivedScope = DeriveScope(map);
        return map.Scope == derivedScope ? map.Scope : derivedScope;
    }

    private static MapScope DeriveScope(MapSummaryDto map)
    {
        if (map.ArcIds.Count > 0)
        {
            return MapScope.ArcScoped;
        }

        if (map.CampaignIds.Count > 0)
        {
            return MapScope.CampaignScoped;
        }

        return MapScope.WorldScoped;
    }

    private string GetMapRoute(Guid mapId) => $"/world/{WorldId}/maps/{mapId}";

    private static string GetDisplayName(string? value, string fallback)
        => string.IsNullOrWhiteSpace(value) ? fallback : value;

    private async Task SyncTreeSelectionAsync()
    {
        try
        {
            if (!TreeState.RootNodes.Any() && !TreeState.IsLoading)
            {
                await TreeState.InitializeAsync();
            }

            var worldNode = TreeState.RootNodes.FirstOrDefault(n =>
                n.NodeType == TreeNodeType.World &&
                n.Id == WorldId);

            var mapsGroupNode = worldNode?.Children.FirstOrDefault(n =>
                n.NodeType == TreeNodeType.VirtualGroup &&
                n.VirtualGroupType == VirtualGroupType.Maps);

            if (mapsGroupNode != null)
            {
                TreeState.ExpandPathToAndSelect(mapsGroupNode.Id);
            }
        }
        catch
        {
            // Tree sync failures should not block page rendering.
        }
    }
}
