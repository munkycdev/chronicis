@page "/world/{WorldId:guid}/maps/{MapId:guid}"
@attribute [Authorize]
@using System.Globalization
@using Chronicis.Client.Components.Shared
@using Chronicis.Shared.DTOs.Maps
@inject IMapApiService MapApi
@inject IWorldApiService WorldApi
@inject IUserApiService UserApi
@inject IArticleApiService ArticleApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ITreeStateService TreeState

@if (_isLoading)
{
    <LoadingSkeleton />
}
else if (_state == MapPageState.NotFound)
{
    <MudAlert Severity="Severity.Error">Map not found.</MudAlert>
}
else if (_state == MapPageState.Unauthorized)
{
    <MudAlert Severity="Severity.Error">You do not have access to this map.</MudAlert>
}
else if (_state == MapPageState.BasemapMissing)
{
    <MudAlert Severity="Severity.Warning">Basemap is missing for this map.</MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="chronicis-article-card chronicis-fade-in">
        <DetailPageHeader Breadcrumbs="_breadcrumbs"
                          Icon="@Icons.Material.Filled.Map"
                          Title="@_editMapName"
                          TitleChanged="OnMapTitleChanged"
                          OnTitleEdited="OnMapTitleEdited"
                          OnEnterPressed="SaveMapNameAsync"
                          Placeholder="Map"
                          ReadOnly="@(!_canManageMap)" />

        @if (_canManageMap)
        {
            <div class="chronicis-flex-between mb-4">
                <SaveStatusIndicator IsSaving="_isSavingMap"
                                     HasUnsavedChanges="_hasUnsavedMapChanges" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveMapNameAsync"
                           Disabled="@(_isSavingMap || !_hasUnsavedMapChanges)"
                           StartIcon="@Icons.Material.Filled.Save">
                    @(_isSavingMap ? "Saving..." : "Save")
                </MudButton>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_mapSaveError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_mapSaveError</MudAlert>
        }

        <div class="map-page__create-pin-controls">
            <MudButton Variant="@(_isCreatePinMode ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary"
                       OnClick="ToggleCreatePinMode"
                       Disabled="@_isCreatingPin"
                       StartIcon="@Icons.Material.Filled.AddLocationAlt">
                @(_isCreatePinMode ? "Create Pin: ON" : "Create Pin")
            </MudButton>

            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @(_isCreatePinMode
                    ? "Click on the map to choose pin details."
                    : "Enable Create Pin, then click map to place a pin.")
            </MudText>
        </div>

        @if (!string.IsNullOrWhiteSpace(_createPinError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_createPinError</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_pinDeleteError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_pinDeleteError</MudAlert>
        }

        <div class="map-page__image-shell" style="@GetMapShellStyle()">
            <div @ref="_mapViewportRef"
                 class="@GetMapViewportClass()"
                 aria-hidden="false"
                 @onclick="OnMapImageShellClick"
                 @onmousedown="OnMapViewportMouseDown"
                 @onmousemove="OnMapViewportMouseMove"
                 @onmouseup="OnMapViewportMouseUp"
                 @onmouseleave="OnMapViewportMouseUp">
                <div class="map-page__map-stage" style="@GetMapStageStyle()">
                    <img @ref="_mapImageRef"
                         src="@_basemapReadUrl"
                         alt="@_mapName"
                         class="@GetMapImageClass()"
                         @onload="OnMapImageLoaded"
                         draggable="false" />
                    <div class="map-page__pins-overlay @(_isCreatePinMode ? "map-page__pins-overlay--create" : string.Empty)"
                         aria-hidden="false">
                        @foreach (var pin in _pins)
                        {
                            @if (pin.LinkedArticle is not null)
                            {
                                <button type="button"
                                        class="@($"map-page__pin map-page__pin--interactive {(_selectedPinId == pin.PinId ? "map-page__pin--selected" : string.Empty)}")"
                                        style="@GetPinStyle(pin)"
                                        title="@GetPinTooltip(pin)"
                                        aria-label="@GetPinAriaLabel(pin)"
                                        @onclick="() => NavigateToLinkedArticleAsync(pin.LinkedArticle.ArticleId)">
                                </button>
                            }
                            else
                            {
                                <div class="@($"map-page__pin {(_selectedPinId == pin.PinId ? "map-page__pin--selected" : string.Empty)}")"
                                     style="@GetPinStyle(pin)"
                                     title="@GetPinTooltip(pin)"
                                     aria-label="@GetPinAriaLabel(pin)"
                                     aria-hidden="true">
                                </div>
                            }

                            @if (HasPinLabel(pin))
                            {
                                <div class="map-page__pin-name" style="@GetPinLabelStyle(pin)" aria-hidden="true">
                                    @pin.Name
                                </div>
                            }

                            @if (!_isCreatePinMode)
                            {
                                <button type="button"
                                        class="@($"map-page__pin-delete-intent {(_selectedPinId == pin.PinId ? "map-page__pin-delete-intent--selected" : string.Empty)}")"
                                        style="@GetPinStyle(pin)"
                                        title="Delete pin"
                                        aria-label="Delete pin"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => SelectPinForDelete(pin.PinId)">
                                    x
                                </button>
                            }
                        }

                        @if (!_isCreatePinMode && SelectedPin is { } selectedPin)
                        {
                            <div class="map-page__pin-delete-confirm"
                                 style="@GetPinStyle(selectedPin)"
                                 @onclick:stopPropagation="true">
                                <span>Delete?</span>
                                <button type="button"
                                        class="map-page__pin-delete-confirm-button"
                                        disabled="@_isDeletingPin"
                                        @onclick="ConfirmDeleteSelectedPinAsync">
                                    @(_isDeletingPin ? "..." : "Confirm")
                                </button>
                                <button type="button"
                                        class="map-page__pin-delete-confirm-button map-page__pin-delete-confirm-button--cancel"
                                        disabled="@_isDeletingPin"
                                        @onclick="CancelDeletePinSelection">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @if (_isCreatePinDialogOpen)
                {
                    <div class="map-page__pin-popup"
                         style="@GetCreatePinPopupStyle()"
                         role="dialog"
                         aria-modal="false"
                         aria-label="Create pin popup"
                         @onclick:stopPropagation="true">
                        <div class="map-page__pin-popup-title">Create pin</div>

                        <label class="map-page__pin-popup-label" for="map-pin-name-input">Name (optional)</label>
                        <input id="map-pin-name-input"
                               class="map-page__pin-popup-input"
                               placeholder="Pin name"
                               value="@_createPinNameInput"
                               @oninput="OnCreatePinNameInput"
                               @onkeydown="OnCreatePinPopupKeyDown"
                               disabled="@_isCreatingPin"
                               autofocus
                               onfocus="this.select();" />

                        <label class="map-page__pin-popup-label" for="map-pin-article-input">Linked Article Id (optional)</label>
                        <input id="map-pin-article-input"
                               class="map-page__pin-popup-input"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                               value="@_createPinArticleIdInput"
                               @oninput="OnCreatePinArticleIdInput"
                               @onkeydown="OnCreatePinPopupKeyDown"
                               disabled="@_isCreatingPin" />

                        <div class="map-page__pin-popup-actions">
                            <button type="button"
                                    class="map-page__pin-popup-button map-page__pin-popup-button--cancel"
                                    disabled="@_isCreatingPin"
                                    @onclick="CancelCreatePinDialog">
                                Cancel
                            </button>
                            <button type="button"
                                    class="map-page__pin-popup-button"
                                    disabled="@_isCreatingPin"
                                    @onclick="ConfirmCreatePinFromDialogAsync">
                                @(_isCreatingPin ? "Creating..." : "Save")
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="map-page__zoom-control" aria-label="Map zoom controls">
                <button type="button"
                        class="map-page__zoom-button"
                        disabled="@(!CanZoomIn())"
                        aria-label="Zoom in"
                        @onclick="ZoomInFromButton">
                    +
                </button>
                <input type="range"
                       class="map-page__zoom-slider"
                       min="0"
                       max="100"
                       step="1"
                       value="@GetZoomSliderValue()"
                       @oninput="OnZoomSliderInput"
                       disabled="@(!_hasMapViewportLayout)"
                       aria-label="Map zoom level" />
                <button type="button"
                        class="map-page__zoom-button"
                        disabled="@(!CanZoomOut())"
                        aria-label="Zoom out"
                        @onclick="ZoomOutFromButton">
                    -
                </button>
            </div>
        </div>
    </MudPaper>
}

@code {
    [Parameter]
    public Guid WorldId { get; set; }

    [Parameter]
    public Guid MapId { get; set; }

    private const double ZoomRangeSliderMax = 100d;
    private const double ZoomButtonSliderStep = 10d;
    private const double ZoomRangeMultiplier = 5d;
    private const double PanDragThresholdPx = 3d;
    private const double PanEnableZoomDelta = 0.0001d;

    private bool _isLoading = true;
    private bool _isSavingMap;
    private bool _hasUnsavedMapChanges;
    private bool _canManageMap;
    private bool _isCreatePinMode;
    private bool _isCreatingPin;
    private bool _isDeletingPin;
    private bool _isCreatePinDialogOpen;
    private MapPageState _state = MapPageState.Loaded;
    private string _worldName = "World";
    private string _mapName = "Map";
    private string _editMapName = "Map";
    private string _mapSaveError = string.Empty;
    private string _createPinError = string.Empty;
    private string _pinDeleteError = string.Empty;
    private string _createPinArticleIdInput = string.Empty;
    private string _createPinNameInput = string.Empty;
    private string _basemapReadUrl = string.Empty;
    private float? _pendingCreatePinX;
    private float? _pendingCreatePinY;
    private float? _pendingCreatePinViewportX;
    private float? _pendingCreatePinViewportY;
    private List<MapPinResponseDto> _pins = [];
    private Guid? _selectedPinId;
    private bool _hasMapViewportLayout;
    private double? _mapPreferredViewportHeightPx;
    private double _mapBaseWidth;
    private double _mapBaseHeight;
    private double _mapViewportWidth;
    private double _mapViewportHeight;
    private double _mapMinZoom = 1d;
    private double _mapMaxZoom = 1d;
    private double _mapZoom = 1d;
    private double _mapPanX;
    private double _mapPanY;
    private bool _isMapPointerDown;
    private bool _isMapDragging;
    private bool _suppressCreatePinClick;
    private double _dragStartClientX;
    private double _dragStartClientY;
    private double _dragStartPanX;
    private double _dragStartPanY;
    private ElementReference _mapViewportRef;
    private ElementReference _mapImageRef;
    private IJSObjectReference? _mapInteropModule;
    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/dashboard"),
        new("World", href: null, disabled: true),
        new("Maps", href: null, disabled: true),
        new("Map", href: null, disabled: true)
    ];

    private enum MapPageState
    {
        Loaded,
        NotFound,
        Unauthorized,
        BasemapMissing,
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _isSavingMap = false;
        _hasUnsavedMapChanges = false;
        _canManageMap = false;
        _state = MapPageState.Loaded;
        _worldName = "World";
        _mapName = "Map";
        _editMapName = "Map";
        _mapSaveError = string.Empty;
        _createPinError = string.Empty;
        _pinDeleteError = string.Empty;
        _createPinArticleIdInput = string.Empty;
        _createPinNameInput = string.Empty;
        _isCreatePinMode = false;
        _isCreatingPin = false;
        _isDeletingPin = false;
        _isCreatePinDialogOpen = false;
        _basemapReadUrl = string.Empty;
        _pendingCreatePinX = null;
        _pendingCreatePinY = null;
        _pendingCreatePinViewportX = null;
        _pendingCreatePinViewportY = null;
        _pins = [];
        _selectedPinId = null;
        _hasMapViewportLayout = false;
        _mapPreferredViewportHeightPx = null;
        _mapBaseWidth = 0d;
        _mapBaseHeight = 0d;
        _mapViewportWidth = 0d;
        _mapViewportHeight = 0d;
        _mapMinZoom = 1d;
        _mapMaxZoom = 1d;
        _mapZoom = 1d;
        _mapPanX = 0d;
        _mapPanY = 0d;
        _isMapPointerDown = false;
        _isMapDragging = false;
        _suppressCreatePinClick = false;
        _dragStartClientX = 0d;
        _dragStartClientY = 0d;
        _dragStartPanX = 0d;
        _dragStartPanY = 0d;
        BuildBreadcrumbs();

        var worldTask = WorldApi.GetWorldAsync(WorldId);
        var userProfileTask = UserApi.GetUserProfileAsync();
        await Task.WhenAll(worldTask, userProfileTask);

        var world = await worldTask;
        if (!string.IsNullOrWhiteSpace(world?.Name))
        {
            _worldName = world.Name;
        }
        _canManageMap = world != null
            && (await userProfileTask)?.Id == world.OwnerId;

        var mapResult = await MapApi.GetMapAsync(WorldId, MapId);
        if (!string.IsNullOrWhiteSpace(mapResult.Map?.Name))
        {
            _mapName = mapResult.Map.Name;
            _editMapName = mapResult.Map.Name;
        }
        if (mapResult.Map != null)
        {
            TreeState.ExpandPathToAndSelect(MapId);
        }
        UpdateMapDirtyState();

        var basemapResult = await MapApi.GetBasemapReadUrlAsync(WorldId, MapId);

        if (IsUnauthorized(mapResult.StatusCode) || IsUnauthorized(basemapResult.StatusCode))
        {
            _state = MapPageState.Unauthorized;
        }
        else if (IsBasemapMissing(basemapResult.StatusCode, basemapResult.Error))
        {
            _state = MapPageState.BasemapMissing;
        }
        else if (mapResult.Map == null || basemapResult.StatusCode == 404)
        {
            _state = MapPageState.NotFound;
        }
        else if (string.IsNullOrWhiteSpace(basemapResult.Basemap?.ReadUrl))
        {
            _state = MapPageState.BasemapMissing;
        }
        else
        {
            _basemapReadUrl = basemapResult.Basemap.ReadUrl;
            _pins = await MapApi.ListPinsForMapAsync(WorldId, MapId);
            _state = MapPageState.Loaded;
            BuildBreadcrumbs();
        }

        _isLoading = false;
    }

    private Task OnMapTitleChanged(string value)
    {
        _editMapName = value;
        return Task.CompletedTask;
    }

    private Task OnMapTitleEdited()
    {
        _mapSaveError = string.Empty;
        UpdateMapDirtyState();
        return Task.CompletedTask;
    }

    private async Task SaveMapNameAsync()
    {
        if (!_canManageMap || _isSavingMap)
        {
            return;
        }

        var trimmedName = (_editMapName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            _mapSaveError = "Map name is required.";
            return;
        }

        if (trimmedName.Length > 200)
        {
            _mapSaveError = "Map name must be 200 characters or fewer.";
            return;
        }

        if (!_hasUnsavedMapChanges)
        {
            return;
        }

        _isSavingMap = true;
        _mapSaveError = string.Empty;

        try
        {
            var updated = await MapApi.UpdateMapAsync(WorldId, MapId, new MapUpdateDto { Name = trimmedName });
            if (updated == null)
            {
                _mapSaveError = "Failed to save map name.";
                return;
            }

            _mapName = updated.Name;
            _editMapName = updated.Name;
            TreeState.UpdateNodeDisplay(MapId, updated.Name, null);
            UpdateMapDirtyState();
            BuildBreadcrumbs();
        }
        catch (Exception ex)
        {
            _mapSaveError = $"Failed to save map name: {ex.Message}";
        }
        finally
        {
            _isSavingMap = false;
        }
    }

    private void UpdateMapDirtyState()
    {
        _hasUnsavedMapChanges = _canManageMap
            && !string.Equals(_editMapName ?? string.Empty, _mapName ?? string.Empty, StringComparison.Ordinal);
    }

    private static bool IsUnauthorized(int? statusCode) => statusCode == 401 || statusCode == 403;

    private void ToggleCreatePinMode()
    {
        _createPinError = string.Empty;
        _selectedPinId = null;
        _isCreatePinMode = !_isCreatePinMode;
        if (!_isCreatePinMode)
        {
            CancelCreatePinDialog();
        }
        else
        {
            _isMapPointerDown = false;
            _isMapDragging = false;
        }
    }

    private string GetMapViewportClass()
    {
        if (_isCreatePinMode)
        {
            return "map-page__viewport map-page__viewport--create";
        }

        if (_isMapDragging)
        {
            return "map-page__viewport map-page__viewport--dragging";
        }

        if (CanPanMap())
        {
            return "map-page__viewport map-page__viewport--pan";
        }

        return "map-page__viewport";
    }

    private string GetMapStageStyle()
    {
        if (!_hasMapViewportLayout)
        {
            return "width:100%;height:auto;transform:translate(0px,0px) scale(1);";
        }

        return string.Create(
            CultureInfo.InvariantCulture,
            $"width:{_mapBaseWidth:F2}px;height:{_mapBaseHeight:F2}px;transform:translate({_mapPanX:F2}px,{_mapPanY:F2}px) scale({_mapZoom:F4});");
    }

    private string GetMapShellStyle()
    {
        if (!_mapPreferredViewportHeightPx.HasValue)
        {
            return "height:clamp(24rem, calc(100vh - 16rem), 78vh);";
        }

        return string.Create(
            CultureInfo.InvariantCulture,
            $"height:min(78vh, max(24rem, {_mapPreferredViewportHeightPx.Value:F2}px));");
    }

    private string GetMapImageClass() =>
        _hasMapViewportLayout
            ? "map-page__image map-page__image--stage"
            : "map-page__image";

    private int GetZoomSliderValue() =>
        GetSliderValueForZoom(_mapZoom, _mapMinZoom, _mapMaxZoom);

    private Task OnZoomSliderInput(ChangeEventArgs args)
    {
        if (!_hasMapViewportLayout || !TryReadDouble(args.Value, out var sliderValue))
        {
            return Task.CompletedTask;
        }

        var clampedSliderValue = Clamp(sliderValue, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(clampedSliderValue, _mapMinZoom, _mapMaxZoom));
        return Task.CompletedTask;
    }

    private bool CanZoomIn() =>
        _hasMapViewportLayout
        && _mapZoom < _mapMaxZoom - PanEnableZoomDelta;

    private bool CanZoomOut() =>
        _hasMapViewportLayout
        && _mapZoom > _mapMinZoom + PanEnableZoomDelta;

    private void ZoomInFromButton()
    {
        if (!CanZoomIn())
        {
            return;
        }

        var nextSliderValue = Clamp(GetZoomSliderValue() + ZoomButtonSliderStep, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(nextSliderValue, _mapMinZoom, _mapMaxZoom));
    }

    private void ZoomOutFromButton()
    {
        if (!CanZoomOut())
        {
            return;
        }

        var nextSliderValue = Clamp(GetZoomSliderValue() - ZoomButtonSliderStep, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(nextSliderValue, _mapMinZoom, _mapMaxZoom));
    }

    private void OnMapViewportMouseDown(MouseEventArgs args)
    {
        if (args.Button != 0 || !CanPanMap())
        {
            return;
        }

        _isMapPointerDown = true;
        _isMapDragging = false;
        _dragStartClientX = args.ClientX;
        _dragStartClientY = args.ClientY;
        _dragStartPanX = _mapPanX;
        _dragStartPanY = _mapPanY;
    }

    private void OnMapViewportMouseMove(MouseEventArgs args)
    {
        if (!_isMapPointerDown)
        {
            return;
        }

        var deltaX = args.ClientX - _dragStartClientX;
        var deltaY = args.ClientY - _dragStartClientY;

        if (!_isMapDragging && Math.Abs(deltaX) < PanDragThresholdPx && Math.Abs(deltaY) < PanDragThresholdPx)
        {
            return;
        }

        _isMapDragging = true;
        _mapPanX = _dragStartPanX + deltaX;
        _mapPanY = _dragStartPanY + deltaY;
        ClampPanToBounds();
    }

    private void OnMapViewportMouseUp(MouseEventArgs _)
    {
        if (_isMapDragging)
        {
            _suppressCreatePinClick = true;
        }

        _isMapPointerDown = false;
        _isMapDragging = false;
    }

    private async Task OnMapImageLoaded()
    {
        await InitializeMapViewportLayoutAsync();
    }

    private async Task InitializeMapViewportLayoutAsync()
    {
        var viewportRect = await GetElementRectAsync(_mapViewportRef);
        var imageRect = await GetElementRectAsync(_mapImageRef);

        if (!HasUsableBounds(viewportRect) || !HasUsableBounds(imageRect))
        {
            return;
        }

        _mapViewportWidth = viewportRect!.Width;
        _mapViewportHeight = viewportRect.Height;
        _mapBaseWidth = imageRect!.Width;
        _mapBaseHeight = imageRect.Height;

        var preferredViewportHeight = _mapViewportWidth * (_mapBaseHeight / _mapBaseWidth);
        var preferredHeightChanged = !_mapPreferredViewportHeightPx.HasValue
            || Math.Abs(_mapPreferredViewportHeightPx.Value - preferredViewportHeight) > 0.5d;
        _mapPreferredViewportHeightPx = preferredViewportHeight;

        if (preferredHeightChanged)
        {
            await InvokeAsync(StateHasChanged);
            var updatedViewportRect = await GetElementRectAsync(_mapViewportRef);
            if (HasUsableBounds(updatedViewportRect))
            {
                _mapViewportWidth = updatedViewportRect!.Width;
                _mapViewportHeight = updatedViewportRect.Height;
            }
        }

        if (_mapBaseWidth <= 0d || _mapBaseHeight <= 0d || _mapViewportWidth <= 0d || _mapViewportHeight <= 0d)
        {
            _hasMapViewportLayout = false;
            return;
        }

        _mapMinZoom = Math.Max(_mapViewportWidth / _mapBaseWidth, _mapViewportHeight / _mapBaseHeight);
        _mapMaxZoom = Math.Max(_mapMinZoom, _mapMinZoom * ZoomRangeMultiplier);
        _mapZoom = _mapMinZoom;
        _hasMapViewportLayout = true;
        RecenterMapPan();
    }

    private bool CanPanMap() =>
        _hasMapViewportLayout
        && !_isCreatePinMode
        && _mapZoom > _mapMinZoom + PanEnableZoomDelta;

    private void SetZoomLevel(double targetZoom)
    {
        if (!_hasMapViewportLayout)
        {
            return;
        }

        var nextZoom = Clamp(targetZoom, _mapMinZoom, _mapMaxZoom);
        if (Math.Abs(nextZoom - _mapZoom) < PanEnableZoomDelta)
        {
            return;
        }

        var centerX = _mapViewportWidth / 2d;
        var centerY = _mapViewportHeight / 2d;
        var mapCenterX = (centerX - _mapPanX) / _mapZoom;
        var mapCenterY = (centerY - _mapPanY) / _mapZoom;

        _mapZoom = nextZoom;
        _mapPanX = centerX - (mapCenterX * _mapZoom);
        _mapPanY = centerY - (mapCenterY * _mapZoom);
        ClampPanToBounds();
    }

    private void RecenterMapPan()
    {
        var scaledWidth = _mapBaseWidth * _mapZoom;
        var scaledHeight = _mapBaseHeight * _mapZoom;

        _mapPanX = (_mapViewportWidth - scaledWidth) / 2d;
        _mapPanY = (_mapViewportHeight - scaledHeight) / 2d;
        ClampPanToBounds();
    }

    private void ClampPanToBounds()
    {
        var scaledWidth = _mapBaseWidth * _mapZoom;
        var scaledHeight = _mapBaseHeight * _mapZoom;
        _mapPanX = ClampPanAxis(_mapPanX, _mapViewportWidth, scaledWidth);
        _mapPanY = ClampPanAxis(_mapPanY, _mapViewportHeight, scaledHeight);
    }

    private static double ClampPanAxis(double pan, double viewportSize, double scaledSize)
    {
        if (viewportSize <= 0d || scaledSize <= 0d)
        {
            return 0d;
        }

        if (scaledSize <= viewportSize)
        {
            return (viewportSize - scaledSize) / 2d;
        }

        return Clamp(pan, viewportSize - scaledSize, 0d);
    }

    private static int GetSliderValueForZoom(double zoom, double minZoom, double maxZoom)
    {
        if (maxZoom <= minZoom)
        {
            return 0;
        }

        var normalized = (zoom - minZoom) / (maxZoom - minZoom);
        return (int)Math.Round(Clamp(normalized * ZoomRangeSliderMax, 0d, ZoomRangeSliderMax), MidpointRounding.AwayFromZero);
    }

    private static double GetZoomForSliderValue(double sliderValue, double minZoom, double maxZoom)
    {
        if (maxZoom <= minZoom)
        {
            return minZoom;
        }

        var normalized = Clamp(sliderValue / ZoomRangeSliderMax, 0d, 1d);
        return minZoom + ((maxZoom - minZoom) * normalized);
    }

    private static bool TryReadDouble(object? value, out double result) =>
        double.TryParse(
            value?.ToString() ?? string.Empty,
            NumberStyles.Float,
            CultureInfo.InvariantCulture,
            out result);

    private static double Clamp(double value, double min, double max) =>
        value < min ? min : value > max ? max : value;

    private bool TryMapClientPointToPinCoordinates(double clientX, double clientY, out float x, out float y, out float viewportX, out float viewportY)
    {
        x = 0f;
        y = 0f;
        viewportX = 0.5f;
        viewportY = 0.5f;

        if (!_hasMapViewportLayout || _mapBaseWidth <= 0d || _mapBaseHeight <= 0d || _mapZoom <= 0d)
        {
            return false;
        }

        var localX = clientX;
        var localY = clientY;
        if (localX < 0d || localY < 0d)
        {
            return false;
        }

        var pinX = Clamp01(((localX - _mapPanX) / _mapZoom) / _mapBaseWidth);
        var pinY = Clamp01(((localY - _mapPanY) / _mapZoom) / _mapBaseHeight);

        x = (float)pinX;
        y = (float)pinY;
        viewportX = (float)Clamp01(localX / _mapViewportWidth);
        viewportY = (float)Clamp01(localY / _mapViewportHeight);
        return true;
    }

