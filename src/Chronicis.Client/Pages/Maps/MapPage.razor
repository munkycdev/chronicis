            return null;
        }

        return layers.FirstOrDefault(l => string.Equals(l.Name, "Arc", StringComparison.Ordinal))?.MapLayerId
            ?? layers.FirstOrDefault(l => string.Equals(l.Name, "Campaign", StringComparison.Ordinal))?.MapLayerId
            ?? layers.FirstOrDefault(l => string.Equals(l.Name, "World", StringComparison.Ordinal))?.MapLayerId
            ?? layers[0].MapLayerId;
    }

