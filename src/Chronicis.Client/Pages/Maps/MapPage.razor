    private async Task OnMapImageShellClick(MouseEventArgs args)
    {
        if (_suppressCreatePinClick)
        {
            _suppressCreatePinClick = false;
            return;
        }

        if (!_isCreatePinMode || _isCreatingPin || _isCreatePinDialogOpen)
        {
            return;
        }

        _createPinError = string.Empty;
        try
        {
            var rect = await GetElementRectAsync(_mapViewportRef);
            if (!HasUsableBounds(rect))
            {
                _createPinError = "Could not determine map bounds for pin placement.";
                return;
            }

            _mapViewportWidth = rect!.Width;
            _mapViewportHeight = rect.Height;

            var localX = args.ClientX - rect.Left;
            var localY = args.ClientY - rect.Top;
            if (!TryMapClientPointToPinCoordinates(localX, localY, out var pinX, out var pinY, out var viewportX, out var viewportY))
            {
                _createPinError = "Could not determine map bounds for pin placement.";
                return;
            }

            _pendingCreatePinX = pinX;
            _pendingCreatePinY = pinY;
            _pendingCreatePinViewportX = viewportX;
            _pendingCreatePinViewportY = viewportY;
            _isCreatePinDialogOpen = true;
        }
        catch (JSException)
        {
            _createPinError = "Could not determine map bounds for pin placement.";
        }
    }

    private void CancelCreatePinDialog()
    {
        _isCreatePinDialogOpen = false;
        _pendingCreatePinX = null;
        _pendingCreatePinY = null;
        _pendingCreatePinViewportX = null;
        _pendingCreatePinViewportY = null;
    }

    private async Task OnCreatePinPopupKeyDown(KeyboardEventArgs args)
    {
        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            await ConfirmCreatePinFromDialogAsync();
        }
    }

    private async Task ConfirmCreatePinFromDialogAsync()
    {
        if (!_isCreatePinDialogOpen || _isCreatingPin)
        {
            return;
        }

        _createPinError = string.Empty;

        if (!TryParseLinkedArticleId(_createPinArticleIdInput, out var linkedArticleId))
        {
            _createPinError = "Linked Article Id must be a valid GUID.";
            return;
        }

        if (!_pendingCreatePinX.HasValue || !_pendingCreatePinY.HasValue)
        {
            _createPinError = "Could not determine map bounds for pin placement.";
            return;
        }

        _isCreatingPin = true;
        try
        {
            var created = await MapApi.CreatePinAsync(
                WorldId,
                MapId,
                new MapPinCreateDto
                {
                    Name = _createPinNameInput,
                    X = _pendingCreatePinX.Value,
                    Y = _pendingCreatePinY.Value,
                    LinkedArticleId = linkedArticleId,
                });

            if (created == null)
            {
                _createPinError = "Failed to create pin.";
                return;
            }

            _pins = _pins
                .Append(created)
                .OrderBy(p => p.PinId)
                .ToList();

            _createPinArticleIdInput = string.Empty;
            _createPinNameInput = string.Empty;
            CancelCreatePinDialog();
        }
        finally
        {
            _isCreatingPin = false;
        }
    }

    private async Task<MapElementRect?> GetElementRectAsync(ElementReference elementRef)
    {
        if (_mapInteropModule == null)
        {
            try
            {
                _mapInteropModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/mapPageInterop.js?v=2");
            }
            catch (JSException)
            {
                // Keep backward compatibility with global script registration.
                return await JSRuntime.InvokeAsync<MapElementRect?>("chronicisMapPage.getElementRect", elementRef);
            }
        }

        try
        {
            var rect = await _mapInteropModule.InvokeAsync<MapElementRect?>("getElementRect", elementRef);
            if (HasUsableBounds(rect))
            {
                return rect;
            }
        }
        catch (JSException)
        {
            // Fall through to global interop fallback.
        }

        return await JSRuntime.InvokeAsync<MapElementRect?>("chronicisMapPage.getElementRect", elementRef);
    }

    private void SelectPinForDelete(Guid pinId)
    {
        _pinDeleteError = string.Empty;
        _selectedPinId = _selectedPinId == pinId ? null : pinId;
    }

    private void CancelDeletePinSelection()
    {
        _selectedPinId = null;
    }

    private async Task ConfirmDeleteSelectedPinAsync()
    {
        if (!_selectedPinId.HasValue || _isDeletingPin)
        {
            return;
        }

        _pinDeleteError = string.Empty;
        _isDeletingPin = true;

        try
        {
            var pinId = _selectedPinId.Value;
            var success = await MapApi.DeletePinAsync(WorldId, MapId, pinId);
            if (!success)
            {
                _pinDeleteError = "Failed to delete pin.";
                return;
            }

            _pins = _pins.Where(p => p.PinId != pinId).ToList();
            _selectedPinId = null;
        }
        finally
        {
            _isDeletingPin = false;
        }
    }

    private async Task NavigateToLinkedArticleAsync(Guid articleId)
    {
        var article = await ArticleApi.GetArticleDetailAsync(articleId);
        if (article == null || !article.Breadcrumbs.Any())
        {
            return;
        }

        var path = string.Join("/", article.Breadcrumbs.Select(b => b.Slug));
        Navigation.NavigateTo($"/article/{path}");
    }

    private static string GetPinStyle(MapPinResponseDto pin) =>
        $"left:{pin.X * 100:F4}%;top:{pin.Y * 100:F4}%;";

    private static string GetPinLabelStyle(MapPinResponseDto pin) =>
        $"left:{pin.X * 100:F4}%;top:{pin.Y * 100:F4}%;";

    private static bool HasPinLabel(MapPinResponseDto pin) =>
        !string.IsNullOrWhiteSpace(pin.Name);

    private static string GetPinTooltip(MapPinResponseDto pin)
    {
        if (!string.IsNullOrWhiteSpace(pin.Name))
        {
            return pin.Name;
        }

        if (pin.LinkedArticle is not null)
        {
            return pin.LinkedArticle.Title;
        }

        return "Map pin";
    }

    private static string GetPinAriaLabel(MapPinResponseDto pin)
    {
        var label = GetPinTooltip(pin);
        return pin.LinkedArticle is not null
            ? $"Open article: {label}"
            : $"Pin: {label}";
    }

    private string GetCreatePinPopupStyle()
    {
        var x = _pendingCreatePinViewportX ?? 0.5f;
        var y = _pendingCreatePinViewportY ?? 0.5f;
        return $"left:{x * 100:F4}%;top:{y * 100:F4}%;";
    }

    private static bool TryParseLinkedArticleId(string value, out Guid? linkedArticleId)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            linkedArticleId = null;
            return true;
        }

        if (Guid.TryParse(value.Trim(), out var parsed))
        {
            linkedArticleId = parsed;
            return true;
        }

        linkedArticleId = null;
        return false;
    }

    private static double Clamp01(double value) =>
        value < 0d ? 0d : value > 1d ? 1d : value;

    private static bool HasUsableBounds(MapElementRect? rect) =>
        rect != null && rect.Width > 0 && rect.Height > 0;

    private sealed class MapElementRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    private static bool IsBasemapMissing(int? statusCode, string? error)
    {
        if (statusCode != 404 || string.IsNullOrWhiteSpace(error))
        {
            return false;
        }

        return error.Contains("basemap", StringComparison.OrdinalIgnoreCase);
    }

    private void BuildBreadcrumbs()
    {
        _breadcrumbs =
        [
            new("Dashboard", href: "/dashboard"),
            new(_worldName, href: $"/world/{WorldId}"),
            new("Maps", href: $"/world/{WorldId}/maps"),
            new(_mapName, href: null, disabled: true)
        ];
    }

    private MapPinResponseDto? SelectedPin =>
        _selectedPinId.HasValue
            ? _pins.FirstOrDefault(p => p.PinId == _selectedPinId.Value)
            : null;
}
