    private async Task OnMapImageShellClick(MouseEventArgs args)
    {
        if (_suppressCreatePinClick)
        {
            _suppressCreatePinClick = false;
            return;
        }

        if (_isCreatePolygonMode)
        {
            await HandlePolygonViewportClickAsync(args);
            return;
        }

        if (TrySelectPolygonAtPoint(args))
        {
            return;
        }

        if (!_isCreatePinMode || _isCreatingPin || _isCreatePinDialogOpen)
        {
            return;
        }

        _createPinError = string.Empty;
        try
        {
            var rect = await GetElementRectAsync(_mapViewportRef);
            if (!HasUsableBounds(rect))
            {
                _createPinError = "Could not determine map bounds for pin placement.";
                return;
            }

            _mapViewportWidth = rect!.Width;
            _mapViewportHeight = rect.Height;

            var localX = args.ClientX - rect.Left;
            var localY = args.ClientY - rect.Top;
            if (!TryMapClientPointToPinCoordinates(localX, localY, out var pinX, out var pinY, out var viewportX, out var viewportY))
            {
                _createPinError = "Could not determine map bounds for pin placement.";
                return;
            }

            _pendingCreatePinX = pinX;
            _pendingCreatePinY = pinY;
            _pendingCreatePinViewportX = viewportX;
            _pendingCreatePinViewportY = viewportY;
            _isCreatePinDialogOpen = true;
        }
        catch (JSException)
        {
            _createPinError = "Could not determine map bounds for pin placement.";
        }
    }

    private async Task HandlePolygonViewportClickAsync(MouseEventArgs args)
    {
        await FocusMapViewportAsync();

        if (_isCreatingPolygon || args.Detail > 1)
        {
            return;
        }

        _createPolygonError = string.Empty;
        _createPolygonStatus = string.Empty;
        if (!TryGetPolygonDraftPoint(args, out var point))
        {
            _createPolygonError = "Could not determine map bounds for polygon creation.";
            Logger.LogWarning("Map {MapId}: polygon vertex add failed because map bounds could not be resolved.", MapId);
            return;
        }

        if (_pendingPolygonClickPoint.HasValue)
        {
            FlushPendingPolygonClick();
        }

        SchedulePolygonVertexAdd(point);
    }

    private async Task OnMapViewportDoubleClickAsync(MouseEventArgs args)
    {
        if (!_isCreatePolygonMode || _isCreatingPolygon)
        {
            return;
        }

        await FocusMapViewportAsync();
        _createPolygonError = string.Empty;
        _createPolygonStatus = string.Empty;

        Logger.LogInformation(
            "Map {MapId}: polygon completion requested. DraftVertices={DraftVertexCount}, SelectedLayerId={SelectedLayerId}, SelectedLayer={SelectedLayer}.",
            MapId,
            _polygonDraft.Vertices.Count,
            SelectedLayerId,
            SelectedLayer?.Name ?? "<none>");

        if (!TryGetPolygonDraftPoint(args, out var completionPoint))
        {
            _createPolygonError = "Could not determine map bounds for polygon creation.";
            Logger.LogWarning("Map {MapId}: polygon completion failed because map bounds could not be resolved.", MapId);
            return;
        }

        CancelPendingPolygonClick();

        if (!_polygonDraft.EndsWith(completionPoint))
        {
            _polygonDraft.AddVertex(completionPoint);
        }

        UpdatePolygonDraftPreview();
        await CompletePolygonDraftAsync();
    }

