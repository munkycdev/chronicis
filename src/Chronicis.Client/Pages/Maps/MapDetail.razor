    {
        _isLoading = true;
        _isSavingMap = false;
        _hasUnsavedMapChanges = false;
        _canManageMap = false;
        _state = MapDetailState.Loaded;
        _worldName = "World";
        _mapName = "Map";
        _editMapName = "Map";
        _mapSaveError = string.Empty;
        _createPinError = string.Empty;
        _createPolygonError = string.Empty;
        _createPolygonStatus = string.Empty;
        _createPolygonColor = DefaultPolygonColor;
        _pinDeleteError = string.Empty;
        _polygonEditError = string.Empty;
        _addLayerError = string.Empty;
        _manageLayerError = string.Empty;
        _createLayerNameInput = string.Empty;
        _createLayerParentLayerId = null;
        _isInlineCreateActive = false;
        _renameLayerNameInput = string.Empty;
        _renameLayerOriginalName = string.Empty;
        _createPinArticleIdInput = string.Empty;
        _createPinNameInput = string.Empty;
        _isCreatePinMode = false;
        _isCreatePolygonMode = false;
        _isCreatingPin = false;
        _isCreatingPolygon = false;
        _isDeletingPin = false;
        _isCreatePinDialogOpen = false;
        _basemapReadUrl = string.Empty;
        _pendingCreatePinX = null;
        _pendingCreatePinY = null;
        _pendingCreatePinViewportX = null;
        _pendingCreatePinViewportY = null;
        SelectedLayerId = null;
        _layers = [];
        _draggedLayerId = null;
        _dropTargetIndex = null;
        _isAddingLayer = false;
        _isRenamingLayer = false;
        _isDeletingLayer = false;
        _editingLayerId = null;
        _pendingDeleteLayerId = null;
        _nestingLayerId = null;
        _selectedNestParentLayerId = null;
        _parentChangeInFlightLayerId = null;
        _isApplyingParentChange = false;
        _isNestParentPickerOpen = false;
        _protectedDefaultLayerIds.Clear();
        _collapsedLayerIds.Clear();
        _eligibleNestParentCandidates.Clear();
        _layerRows.Clear();
        _pins = [];
        _polygonsByFeatureId.Clear();
        _selectedPinId = null;
        _selectedPolygonFeatureId = null;
        _selectedPolygonOriginalGeometry = null;
        _selectedPolygonWorkingGeometry = null;
        _selectedPolygonOriginalName = string.Empty;
        _selectedPolygonName = string.Empty;
        _selectedPolygonOriginalColor = DefaultPolygonColor;
        _selectedPolygonColor = DefaultPolygonColor;
        _activePolygonVertexIndex = null;
        _isDraggingPolygonVertex = false;
        _isSavingPolygonEdit = false;
        _isDeletingPolygon = false;
        _hasMapViewportLayout = false;
        _mapPreferredViewportHeightPx = null;
        _mapBaseWidth = 0d;
        _mapBaseHeight = 0d;
        _mapViewportWidth = 0d;
        _mapViewportHeight = 0d;
        _mapViewportLeft = 0d;
        _mapViewportTop = 0d;
        _mapMinZoom = 1d;
        _mapMaxZoom = 1d;
        _mapZoom = 1d;
        _mapPanX = 0d;
        _mapPanY = 0d;
        _isMapPointerDown = false;
        _isMapDragging = false;
        _suppressCreatePinClick = false;
        ClearPolygonDraft();
        _dragStartClientX = 0d;
        _dragStartClientY = 0d;
        _dragStartPanX = 0d;
        _dragStartPanY = 0d;
        _polygonVertexDragStartLocalX = 0d;
        _polygonVertexDragStartLocalY = 0d;
        _polygonVertexDragStartClientX = 0d;
        _polygonVertexDragStartClientY = 0d;
        _hasPolygonVertexDragClientAnchor = false;
        _shouldFocusCreateLayerInput = false;
        _shouldFocusRenameLayerInput = false;
        _shouldFocusMapViewport = false;
        BuildBreadcrumbs();

        var worldTask = WorldApi.GetWorldAsync(WorldId);
        var userProfileTask = UserApi.GetUserProfileAsync();
        await Task.WhenAll(worldTask, userProfileTask);

        var world = await worldTask;
        if (!string.IsNullOrWhiteSpace(world?.Name))
        {
            _worldName = world.Name;
        }
        _canManageMap = world != null
            && (await userProfileTask)?.Id == world.OwnerId;

        var mapResult = await MapApi.GetMapAsync(WorldId, MapId);
        if (!string.IsNullOrWhiteSpace(mapResult.Map?.Name))
        {
            _mapName = mapResult.Map.Name;
            _editMapName = mapResult.Map.Name;
        }
        if (mapResult.Map != null)
        {
            TreeState.ExpandPathToAndSelect(MapId);
        }
        UpdateMapDirtyState();

        var basemapResult = await MapApi.GetBasemapReadUrlAsync(WorldId, MapId);

        if (IsUnauthorized(mapResult.StatusCode) || IsUnauthorized(basemapResult.StatusCode))
        {
            _state = MapDetailState.Unauthorized;
        }
        else if (IsBasemapMissing(basemapResult.StatusCode, basemapResult.Error))
        {
            _state = MapDetailState.BasemapMissing;
        }
        else if (mapResult.Map == null || basemapResult.StatusCode == 404)
        {
            _state = MapDetailState.NotFound;
        }
        else if (string.IsNullOrWhiteSpace(basemapResult.Basemap?.ReadUrl))
        {
            _state = MapDetailState.BasemapMissing;
        }
        else
        {
            _basemapReadUrl = basemapResult.Basemap.ReadUrl;
            var layers = await MapApi.GetLayersForMapAsync(WorldId, MapId);
            _layers = layers?.OrderBy(l => l.SortOrder).ToList() ?? [];
            InitializeProtectedDefaultLayerIds(_layers);
            RebuildLayerRows();
            if (SelectedLayerId == null)
            {
                SelectedLayerId = ResolveDefaultSelectedLayerId(_layers);
            }
            _pins = await MapApi.ListPinsForMapAsync(WorldId, MapId);
            var features = await MapApi.ListFeaturesForMapAsync(WorldId, MapId);
            SetRenderedPolygons(features);
            ReconcileSelectedPolygonState();
            _state = MapDetailState.Loaded;
            BuildBreadcrumbs();
        }

        _isLoading = false;
    }

    private Task OnMapTitleChanged(string value)
    {
        _editMapName = value;
        return Task.CompletedTask;
    }

    private Task OnMapTitleEdited()
    {
        _mapSaveError = string.Empty;
        UpdateMapDirtyState();
        return Task.CompletedTask;
    }

    private async Task SaveMapNameAsync()
    {
        if (!_canManageMap || _isSavingMap)
        {
            return;
        }

        var trimmedName = (_editMapName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            _mapSaveError = "Map name is required.";
            return;
        }

        if (trimmedName.Length > 200)
        {
            _mapSaveError = "Map name must be 200 characters or fewer.";
            return;
        }

        if (!_hasUnsavedMapChanges)
        {
            return;
        }

        _isSavingMap = true;
        _mapSaveError = string.Empty;

        try
        {
            var updated = await MapApi.UpdateMapAsync(WorldId, MapId, new MapUpdateDto { Name = trimmedName });
            if (updated == null)
            {
                _mapSaveError = "Failed to save map name.";
                return;
            }

            _mapName = updated.Name;
            _editMapName = updated.Name;
            TreeState.UpdateNodeDisplay(MapId, updated.Name, null);
            UpdateMapDirtyState();
            BuildBreadcrumbs();
        }
        catch (Exception ex)
        {
            _mapSaveError = $"Failed to save map name: {ex.Message}";
        }
        finally
        {
            _isSavingMap = false;
        }
    }

    private void UpdateMapDirtyState()
    {
        _hasUnsavedMapChanges = _canManageMap
            && !string.Equals(_editMapName ?? string.Empty, _mapName ?? string.Empty, StringComparison.Ordinal);
    }

    private static bool IsUnauthorized(int? statusCode) => statusCode == 401 || statusCode == 403;

    private static Guid? ResolveDefaultSelectedLayerId(List<MapLayerDto> layers)
    {
        if (layers.Count == 0)
        {
            return null;
        }

        return layers.FirstOrDefault(l => string.Equals(l.Name, "Arc", StringComparison.Ordinal))?.MapLayerId
            ?? layers.FirstOrDefault(l => string.Equals(l.Name, "Campaign", StringComparison.Ordinal))?.MapLayerId
            ?? layers.FirstOrDefault(l => string.Equals(l.Name, "World", StringComparison.Ordinal))?.MapLayerId
            ?? layers[0].MapLayerId;
    }

    private void OnLayerRowSelected(Guid layerId)
    {
        SelectedLayerId = layerId;
    }

    private void InitializeProtectedDefaultLayerIds(IEnumerable<MapLayerDto> layers)
    {
        _protectedDefaultLayerIds.Clear();
        foreach (var layer in layers.Where(layer =>
                     string.Equals(layer.Name, "World", StringComparison.Ordinal)
                     || string.Equals(layer.Name, "Campaign", StringComparison.Ordinal)
                     || string.Equals(layer.Name, "Arc", StringComparison.Ordinal)))
        {
            _protectedDefaultLayerIds.Add(layer.MapLayerId);
        }
    }

    private bool IsProtectedDefaultLayer(Guid layerId) =>
        _protectedDefaultLayerIds.Contains(layerId);

    private bool IsEditingLayer(Guid layerId) =>
        _editingLayerId == layerId;

    private bool IsPendingDeleteLayer(Guid layerId) =>
        _pendingDeleteLayerId == layerId;

    private bool CanBeginLayerRename(Guid layerId)
    {
        if (_isRenamingLayer || _isInlineCreateActive || IsProtectedDefaultLayer(layerId))
        {
            return false;
        }

        if (!_editingLayerId.HasValue)
        {
            return true;
        }

        return _editingLayerId.Value == layerId;
    }

    private bool CanBeginInlineLayerCreate(Guid? parentLayerId)
    {
        if (_isAddingLayer || _isRenamingLayer || _isInlineCreateActive || _editingLayerId.HasValue)
        {
            return false;
        }

        return !parentLayerId.HasValue
            || _layers.Any(layer => layer.MapLayerId == parentLayerId.Value);
    }

    private void BeginAddRootLayer()
    {
        BeginInlineLayerCreate(parentLayerId: null);
    }

    private void BeginAddChildLayer(Guid parentLayerId)
    {
        BeginInlineLayerCreate(parentLayerId);
    }

    private void BeginInlineLayerCreate(Guid? parentLayerId)
    {
        if (!CanBeginInlineLayerCreate(parentLayerId))
        {
            return;
        }

        if (parentLayerId.HasValue)
        {
            ExpandAncestorChain(parentLayerId.Value, includeSelf: true);
        }

        _createLayerNameInput = string.Empty;
        _createLayerParentLayerId = parentLayerId;
        _isInlineCreateActive = true;
        _shouldFocusCreateLayerInput = true;
        _addLayerError = string.Empty;
        _manageLayerError = string.Empty;
        _pendingDeleteLayerId = null;
        CancelNestLayer();
    }

    private void OnCreateLayerNameInput(ChangeEventArgs args)
    {
        _createLayerNameInput = args.Value?.ToString() ?? string.Empty;
        _addLayerError = string.Empty;
    }

    private Task OnCreateLayerNameKeyDown(KeyboardEventArgs args)
    {
        if (!_isInlineCreateActive || _isAddingLayer)
        {
            return Task.CompletedTask;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return SaveCreatedLayerAsync();
        }

        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            CancelInlineLayerCreate();
        }

        return Task.CompletedTask;
    }

    private async Task SaveCreatedLayerAsync()
    {
        if (_isAddingLayer || !_isInlineCreateActive)
        {
            return;
        }

        var layerName = (_createLayerNameInput ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(layerName))
        {
            _addLayerError = "Layer name is required.";
            return;
        }

        if (layerName.Length > 200)
        {
            _addLayerError = "Layer name must be 200 characters or fewer.";
            return;
        }

        _isAddingLayer = true;
        _addLayerError = string.Empty;
        _manageLayerError = string.Empty;

        try
        {
            var createdLayer = await MapApi.CreateLayerAsync(
                WorldId,
                MapId,
                layerName,
                _createLayerParentLayerId);

            if (createdLayer.ParentLayerId.HasValue)
            {
                ExpandAncestorChain(createdLayer.ParentLayerId.Value, includeSelf: true);
            }
            else if (_createLayerParentLayerId.HasValue)
            {
                ExpandAncestorChain(_createLayerParentLayerId.Value, includeSelf: true);
            }

            _layers.Add(createdLayer);
            _layers = _layers.OrderBy(l => l.SortOrder).ToList();
            RebuildLayerRows();
            SelectedLayerId = createdLayer.MapLayerId;
            ClearInlineLayerCreateState();
        }
        catch (Exception ex)
        {
            _addLayerError = $"Failed to add layer: {ex.Message}";
        }
        finally
        {
            _isAddingLayer = false;
        }
    }

    private void CancelInlineLayerCreate()
    {
        if (_isAddingLayer)
        {
            return;
        }

        ClearInlineLayerCreateState();
        _addLayerError = string.Empty;
    }

    private void ClearInlineLayerCreateState()
    {
        _isInlineCreateActive = false;
        _createLayerParentLayerId = null;
        _createLayerNameInput = string.Empty;
        _shouldFocusCreateLayerInput = false;
    }

    private int GetInlineCreateDepth()
    {
        if (!_isInlineCreateActive || !_createLayerParentLayerId.HasValue)
        {
            return 0;
        }

        var parentRow = _layerRows.FirstOrDefault(row => row.Layer.MapLayerId == _createLayerParentLayerId.Value);
        return parentRow == null ? 0 : parentRow.Depth + 1;
    }

    private List<LayerTreeNode> BuildVisibleLayerTree()
    {
        var roots = new List<LayerTreeNode>();
        var stack = new Stack<LayerTreeNode>();

        for (var visibleIndex = 0; visibleIndex < _layerRows.Count; visibleIndex++)
        {
            var node = new LayerTreeNode(_layerRows[visibleIndex]);
            while (stack.Count > 0 && stack.Peek().Row.Depth >= node.Row.Depth)
            {
                stack.Pop();
            }

            if (stack.Count == 0)
            {
                roots.Add(node);
            }
            else
            {
                stack.Peek().Children.Add(node);
            }

            stack.Push(node);
        }

        return roots;
    }

    private RenderFragment RenderLayerTreeNode(
        LayerTreeNode node,
        IReadOnlySet<Guid> effectivelyVisibleLayerIds) => @<MudTreeViewItem T="Guid"
                         @key="node.Row.Layer.MapLayerId"
                         Value="@node.Row.Layer.MapLayerId"
                         Class="map-page__layer-tree-item"
                         CanExpand="@node.Row.HasChildren"
                         Expanded="@(!node.Row.IsCollapsed)"
                         ExpandedChanged="@((bool expanded) => SetLayerExpandedState(node.Row.Layer.MapLayerId, expanded))">
            <BodyContent>
                @RenderLayerRow(node.Row, effectivelyVisibleLayerIds)
            </BodyContent>
            <ChildContent>
                @foreach (var child in node.Children)
                {
                    @RenderLayerTreeNode(child, effectivelyVisibleLayerIds)
                }
            </ChildContent>
        </MudTreeViewItem>;

    private RenderFragment RenderLayerRow(LayerRenderRow layerRow, IReadOnlySet<Guid> effectivelyVisibleLayerIds) => @<div class="@GetLayerRowClass(layerRow, effectivelyVisibleLayerIds)"
         data-layer-id="@layerRow.Layer.MapLayerId"
         data-layer-depth="@layerRow.Depth"
         draggable="true"
         @ondragstart="args => OnLayerDragStart(layerRow.Layer.MapLayerId, args)"
         @ondragenter="() => OnLayerDragEnter(layerRow.FlatIndex)"
         @ondragover="() => OnLayerDragOver(layerRow.FlatIndex)"
         @ondragover:preventDefault="true"
         @ondrop="() => OnLayerDropAsync(layerRow.FlatIndex)"
         @ondrop:preventDefault="true"
         @ondragend="OnLayerDragEnd"
         @onclick="@(() => OnLayerRowSelected(layerRow.Layer.MapLayerId))">
        <span class="map-page__layer-drag-handle" aria-hidden="true">::</span>
        <input type="checkbox"
               class="map-page__layer-toggle"
               checked="@layerRow.Layer.IsEnabled"
               @onclick:stopPropagation="true"
               @onchange="args => OnLayerVisibilityChangedAsync(layerRow.Layer.MapLayerId, args)" />
        @if (IsEditingLayer(layerRow.Layer.MapLayerId))
        {
            <input type="text"
                   class="map-page__layer-rename-input"
                   @ref="_renameLayerInputRef"
                   value="@_renameLayerNameInput"
                   @onclick:stopPropagation="true"
                   @oninput="OnRenameLayerNameInput"
                   @onkeydown="args => OnRenameLayerNameKeyDown(layerRow.Layer.MapLayerId, args)"
                   disabled="@_isRenamingLayer" />
            <div class="map-page__layer-actions">
                <button type="button"
                        class="map-page__layer-action-button"
                        @onclick:stopPropagation="true"
                        @onclick="() => ConfirmLayerRenameAsync(layerRow.Layer.MapLayerId)"
                        disabled="@_isRenamingLayer">
                    @(_isRenamingLayer ? "Saving..." : "Save")
                </button>
                <button type="button"
                        class="map-page__layer-action-button map-page__layer-action-button--cancel"
                        @onclick:stopPropagation="true"
                        @onclick="CancelLayerRename"
                        disabled="@_isRenamingLayer">
                    Cancel
                </button>
            </div>
        }
        else if (!IsProtectedDefaultLayer(layerRow.Layer.MapLayerId))
        {
            <button type="button"
                    class="map-page__layer-name-button"
                    @onclick:stopPropagation="true"
                    @onclick="() => BeginLayerRename(layerRow.Layer.MapLayerId)"
                    disabled="@(!CanBeginLayerRename(layerRow.Layer.MapLayerId))">
                <span class="map-page__layer-name">@layerRow.Layer.Name</span>
            </button>
        }
        else
        {
            <span class="map-page__layer-name">@layerRow.Layer.Name</span>
        }

        @if (!IsProtectedDefaultLayer(layerRow.Layer.MapLayerId) && !IsEditingLayer(layerRow.Layer.MapLayerId))
        {
            <div class="map-page__layer-actions">
                @if (IsPendingDeleteLayer(layerRow.Layer.MapLayerId))
                {
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-action-button--danger"
                            @onclick:stopPropagation="true"
                            @onclick="() => ConfirmLayerDeleteAsync(layerRow.Layer.MapLayerId)"
                            disabled="@_isDeletingLayer">
                        @(_isDeletingLayer ? "Deleting..." : "Confirm")
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-action-button--cancel"
                            @onclick:stopPropagation="true"
                            @onclick="CancelLayerDelete"
                            disabled="@_isDeletingLayer">
                        Cancel
                    </button>
                }
                else
                {
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-add-child-button"
                            @onclick:stopPropagation="true"
                            @onclick="() => BeginAddChildLayer(layerRow.Layer.MapLayerId)"
                            disabled="@(!CanBeginInlineLayerCreate(layerRow.Layer.MapLayerId))">
                        Add Child Layer
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-delete-button"
                            @onclick:stopPropagation="true"
                            @onclick="() => BeginLayerDelete(layerRow.Layer.MapLayerId)">
                        Delete
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-nest-button"
                            @onclick:stopPropagation="true"
                            @onclick="() => BeginNestLayer(layerRow.Layer.MapLayerId)"
                            disabled="@(_isApplyingParentChange || _parentChangeInFlightLayerId.HasValue)">
                        Nest under...
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-root-button"
                            @onclick:stopPropagation="true"
                            @onclick="() => MoveLayerToRootAsync(layerRow.Layer.MapLayerId)"
                            disabled="@(layerRow.Layer.ParentLayerId == null || _isApplyingParentChange || _parentChangeInFlightLayerId.HasValue)">
                        Move to root
                    </button>
                }
