@page "/world/{WorldId:guid}/maps/{MapId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable
@using System.Globalization
@using Chronicis.Client.Engine.Geometry
@using Chronicis.Client.Engine.Interaction
@using Chronicis.Client.Components.Shared
@using Chronicis.Client.Utilities
@using Chronicis.Shared.DTOs.Maps
@using Chronicis.Shared.Enums
@inject IMapApiService MapApi
@inject IWorldApiService WorldApi
@inject IUserApiService UserApi
@inject IArticleApiService ArticleApi
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject ITreeStateService TreeState
@inject ILogger<MapDetail> Logger

@if (_isLoading)
{
    <LoadingSkeleton />
}
else if (_state == MapDetailState.NotFound)
{
    <MudAlert Severity="Severity.Error">Map not found.</MudAlert>
}
else if (_state == MapDetailState.Unauthorized)
{
    <MudAlert Severity="Severity.Error">You do not have access to this map.</MudAlert>
}
else if (_state == MapDetailState.BasemapMissing)
{
    <MudAlert Severity="Severity.Warning">Basemap is missing for this map.</MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="chronicis-article-card chronicis-fade-in">
        <DetailPageHeader Breadcrumbs="_breadcrumbs"
                          Icon="@Icons.Material.Filled.Map"
                          Title="@_editMapName"
                          TitleChanged="OnMapTitleChanged"
                          OnTitleEdited="OnMapTitleEdited"
                          OnEnterPressed="SaveMapNameAsync"
                          Placeholder="Map"
                          ReadOnly="@(!_canManageMap)" />

        @if (_canManageMap)
        {
            <div class="chronicis-flex-between mb-4">
                <SaveStatusIndicator IsSaving="_isSavingMap"
                                     HasUnsavedChanges="_hasUnsavedMapChanges" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveMapNameAsync"
                           Disabled="@(_isSavingMap || !_hasUnsavedMapChanges)"
                           StartIcon="@Icons.Material.Filled.Save">
                    @(_isSavingMap ? "Saving..." : "Save")
                </MudButton>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_mapSaveError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_mapSaveError</MudAlert>
        }

        @if (_layers.Count > 0)
        {
            <div class="map-page__layers-panel" aria-label="Map layers">
                @if (!string.IsNullOrWhiteSpace(_addLayerError))
                {
                    <div class="map-page__layer-add-error">@_addLayerError</div>
                }
                @if (!string.IsNullOrWhiteSpace(_manageLayerError))
                {
                    <div class="map-page__layer-add-error">@_manageLayerError</div>
                }
                @if (_isNestParentPickerOpen && _nestingLayerId.HasValue)
                {
                    <div class="map-page__layer-parent-picker" role="group" aria-label="Nest layer under parent">
                        <select class="map-page__layer-parent-select"
                                value="@(_selectedNestParentLayerId?.ToString() ?? string.Empty)"
                                @onchange="OnNestParentSelectionChanged"
                                disabled="@_isApplyingParentChange">
                            <option value="">Choose parent layer...</option>
                            @foreach (var candidate in _eligibleNestParentCandidates)
                            {
                                <option value="@candidate.MapLayerId.ToString()">@candidate.Name</option>
                            }
                        </select>
                        <button type="button"
                                class="map-page__layer-action-button"
                                disabled="@(!_selectedNestParentLayerId.HasValue || _isApplyingParentChange)"
                                @onclick="ConfirmNestLayerAsync">
                            @(_isApplyingParentChange ? "Saving..." : "Confirm")
                        </button>
                        <button type="button"
                                class="map-page__layer-action-button map-page__layer-action-button--cancel"
                                disabled="@_isApplyingParentChange"
                                @onclick="CancelNestLayer">
                            Cancel
                        </button>
                    </div>
                }

                @{
                    var effectivelyVisibleLayerIds = GetEffectivelyVisibleLayerIds();
                    var createDepth = GetInlineCreateDepth();
                    var layerTreeRoots = BuildVisibleLayerTree();
                }
                <MudTreeView T="Guid"
                             Dense="true"
                             Hover="false"
                             ReadOnly="true"
                             Ripple="false"
                             ExpandOnClick="false"
                             Class="map-page__layer-tree">
                    @foreach (var rootNode in layerTreeRoots)
                    {
                        @RenderLayerTreeNode(rootNode, effectivelyVisibleLayerIds)
                    }
                </MudTreeView>
                @if (_isInlineCreateActive)
                {
                    @RenderInlineCreateRow(createDepth)
                }

                <div class="map-page__layer-footer-actions">
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-add-root-button"
                            @onclick="BeginAddRootLayer"
                            disabled="@(!CanBeginInlineLayerCreate(parentLayerId: null))">
                        Add Root-Level Layer
                    </button>
                </div>
            </div>
        }

        <div class="map-page__create-pin-controls">
            <MudButton Variant="@(_isCreatePinMode ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary"
                       OnClick="ToggleCreatePinMode"
                       Disabled="@_isCreatingPin"
                       StartIcon="@Icons.Material.Filled.AddLocationAlt">
                @(_isCreatePinMode ? "Create Pin: ON" : "Create Pin")
            </MudButton>

            <MudButton Variant="@(_isCreatePolygonMode ? Variant.Filled : Variant.Outlined)"
                       Color="Color.Primary"
                       OnClick="ToggleCreatePolygonMode"
                       Disabled="@_isCreatingPolygon"
                       StartIcon="@Icons.Material.Filled.ChangeHistory">
                @(_isCreatePolygonMode ? "Create Polygon: ON" : "Create Polygon")
            </MudButton>

            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @GetMapInteractionHelpText()
            </MudText>

            @if (SelectedLayer is { } selectedLayer)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary map-page__selected-layer-status">
                    Active layer: <strong>@selectedLayer.Name</strong>
                    @if (_isCreatePolygonMode && !IsSelectedLayerEffectivelyVisible)
                    {
                        <span class="map-page__selected-layer-status--warning">(hidden by layer visibility)</span>
                    }
                </MudText>
            }
        </div>

        @if (_isCreatePolygonMode && !SelectedLayerId.HasValue)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">Select a layer before saving a polygon.</MudAlert>
        }

        @if (_isCreatePolygonMode && SelectedLayerId.HasValue && !IsSelectedLayerEffectivelyVisible)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">Selected layer is hidden. Enable it (and any parent layers) before saving polygons.</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_createPolygonStatus))
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">@_createPolygonStatus</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_createPinError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_createPinError</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_createPolygonError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_createPolygonError</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_pinDeleteError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_pinDeleteError</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_polygonEditError))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_polygonEditError</MudAlert>
        }

        @if (_isCreatePolygonMode)
        {
            <div class="map-page__polygon-editor" aria-label="Polygon editor">
                <span class="map-page__polygon-editor-title">
                    Editing polygon
                    <span class="map-page__polygon-editor-name">Draft</span>
                </span>
                <span class="map-page__polygon-editor-status">
                    @GetCreatePolygonEditorStatus()
                </span>
                <div class="map-page__polygon-editor-color">
                    <label class="map-page__polygon-editor-color-label" for="create-polygon-color">Color</label>
                    <select id="create-polygon-color"
                            class="map-page__polygon-color-select"
                            value="@_createPolygonColor"
                            disabled="@_isCreatingPolygon"
                            @onchange="OnCreatePolygonColorChanged">
                        @foreach (var option in PolygonColorOptions)
                        {
                            <option value="@option.Key">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="map-page__polygon-editor-actions">
                    <button type="button"
                            class="map-page__layer-action-button"
                            disabled="@_isCreatingPolygon"
                            @onclick="SaveCreatePolygonDraftAsync">
                        @(_isCreatingPolygon ? "Saving..." : "Save")
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-action-button--cancel"
                            disabled="@_isCreatingPolygon"
                            @onclick="CancelCreatePolygonDraft">
                        Cancel
                    </button>
                </div>
            </div>
        }
        else if (SelectedPolygonRenderModel is { } selectedPolygon)
        {
            <div class="map-page__polygon-editor" aria-label="Polygon editor">
                <span class="map-page__polygon-editor-title">
                    Editing polygon
                    @if (!string.IsNullOrWhiteSpace(selectedPolygon.DisplayName))
                    {
                        <span class="map-page__polygon-editor-name">@selectedPolygon.DisplayName</span>
                    }
                </span>
                <span class="map-page__polygon-editor-status">
                    @(IsSelectedPolygonDirty ? "Unsaved changes" : "Selected")
                </span>
                <div class="map-page__polygon-editor-name-field">
                    <label class="map-page__polygon-editor-color-label" for="selected-polygon-name">Name</label>
                    <input id="selected-polygon-name"
                           class="map-page__polygon-name-input"
                           value="@_selectedPolygonName"
                           maxlength="200"
                           disabled="@IsPolygonEditInteractionLocked"
                           @oninput="OnSelectedPolygonNameInput" />
                </div>
                <div class="map-page__polygon-editor-color">
                    <label class="map-page__polygon-editor-color-label" for="selected-polygon-color">Color</label>
                    <select id="selected-polygon-color"
                            class="map-page__polygon-color-select"
                            value="@_selectedPolygonColor"
                            disabled="@IsPolygonEditInteractionLocked"
                            @onchange="OnSelectedPolygonColorChanged">
                        @foreach (var option in PolygonColorOptions)
                        {
                            <option value="@option.Key">@option.Label</option>
                        }
                    </select>
                </div>
                <div class="map-page__polygon-editor-actions">
                    <button type="button"
                            class="map-page__layer-action-button"
                            disabled="@(!IsSelectedPolygonDirty || IsPolygonEditInteractionLocked)"
                            @onclick="SaveSelectedPolygonAsync">
                        @(_isSavingPolygonEdit ? "Saving..." : "Save")
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-action-button--cancel"
                            disabled="@(!IsSelectedPolygonDirty || IsPolygonEditInteractionLocked)"
                            @onclick="CancelSelectedPolygonEdit">
                        Cancel
                    </button>
                    <button type="button"
                            class="map-page__layer-action-button map-page__layer-action-button--danger"
                            disabled="@IsPolygonEditInteractionLocked"
                            @onclick="DeleteSelectedPolygonAsync">
                        @(_isDeletingPolygon ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        }

        <div class="map-page__image-shell" style="@GetMapShellStyle()">
            <div @ref="_mapViewportRef"
                 class="@GetMapViewportClass()"
                 aria-hidden="false"
                 tabindex="0"
                 @onclick="OnMapImageShellClick"
                 @ondblclick="OnMapViewportDoubleClickAsync"
                 @onkeydown="OnMapViewportKeyDown"
                 @onkeydown:preventDefault="ShouldPreventMapViewportKeyDefault"
                 @onmousedown="OnMapViewportMouseDown"
                 @onmousemove="OnMapViewportMouseMove"
                 @onmouseup="OnMapViewportMouseUp"
                 @onmouseleave="OnMapViewportMouseLeave">
                <div class="map-page__map-stage" style="@GetMapStageStyle()">
                    <img @ref="_mapImageRef"
                         src="@_basemapReadUrl"
                         alt="@_mapName"
                         class="@GetMapImageClass()"
                         @onload="OnMapImageLoaded"
                         draggable="false" />
                    <svg class="map-page__polygons-overlay"
                         viewBox="0 0 1 1"
                         preserveAspectRatio="none"
                         aria-hidden="true">
                        @foreach (var polygon in GetVisiblePolygons())
                        {
                            <path class="@GetPolygonClass(polygon)"
                                  d="@polygon.PathData"
                                  style="@GetPolygonStyle(polygon)"
                                  data-feature-id="@polygon.FeatureId.ToString()"
                                  data-layer-id="@polygon.LayerId.ToString()">
                            </path>
                        }
                        @if (_isCreatePolygonMode && !string.IsNullOrWhiteSpace(_polygonDraftPathData))
                        {
                            <path class="map-page__polygon-draft" d="@_polygonDraftPathData"></path>
                        }
                    </svg>
                    <div class="map-page__polygon-points-overlay" aria-hidden="true">
                        @if (SelectedPolygonRenderModel is { } editablePolygon)
                        {
                            @foreach (var vertex in GetEditablePolygonVertices(editablePolygon.Geometry))
                            {
                                <span class="@GetPolygonVertexClass(vertex.Index)"
                                      style="@GetPolygonPointStyle(vertex.Point)"
                                      data-polygon-vertex-index="@vertex.Index.ToString(CultureInfo.InvariantCulture)"
                                      @onmousedown:stopPropagation="true"
                                      @onmousedown="args => OnPolygonVertexMouseDown(args, vertex.Index)">⊙</span>
                            }
                        }
                        @if (_isCreatePolygonMode)
                        {
                            @foreach (var vertex in _polygonDraft.Vertices)
                            {
                                <span class="map-page__polygon-draft-vertex"
                                      style="@GetPolygonPointStyle(vertex)">⊙</span>
                            }
                        }
                    </div>
                    <div class="map-page__polygon-labels-overlay" aria-hidden="true">
                        @foreach (var polygon in GetVisiblePolygons())
                        {
                            @if (!string.IsNullOrWhiteSpace(polygon.DisplayName)
                                && TryGetPolygonLabelPosition(polygon.Geometry, out var labelPoint))
                            {
                                <div class="map-page__polygon-label"
                                     style="@GetPolygonLabelStyle(labelPoint)"
                                     data-feature-id="@polygon.FeatureId.ToString()">
                                    @polygon.DisplayName
                                </div>
                            }
                        }
                    </div>
                    <div class="map-page__pins-overlay @(_isCreatePinMode ? "map-page__pins-overlay--create" : string.Empty) @(_isCreatePolygonMode ? "map-page__pins-overlay--polygon-create" : string.Empty)"
                         aria-hidden="false">
                        @foreach (var pin in GetVisiblePins())
                        {
                            @if (pin.LinkedArticle is not null)
                            {
                                <button type="button"
                                        class="@($"map-page__pin map-page__pin--interactive {(_selectedPinId == pin.PinId ? "map-page__pin--selected" : string.Empty)}")"
                                        style="@GetPinStyle(pin)"
                                        title="@GetPinTooltip(pin)"
                                        aria-label="@GetPinAriaLabel(pin)"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => NavigateToLinkedArticleAsync(pin.LinkedArticle.ArticleId)">
                                </button>
                            }
                            else
                            {
                                <div class="@($"map-page__pin {(_selectedPinId == pin.PinId ? "map-page__pin--selected" : string.Empty)}")"
                                     style="@GetPinStyle(pin)"
                                     title="@GetPinTooltip(pin)"
                                     aria-label="@GetPinAriaLabel(pin)"
                                     aria-hidden="true">
                                </div>
                            }

                            @if (HasPinLabel(pin))
                            {
                                <div class="map-page__pin-name" style="@GetPinLabelStyle(pin)" aria-hidden="true">
                                    @pin.Name
                                </div>
                            }

                            @if (!_isCreatePinMode)
                            {
                                <button type="button"
                                        class="@($"map-page__pin-delete-intent {(_selectedPinId == pin.PinId ? "map-page__pin-delete-intent--selected" : string.Empty)}")"
                                        style="@GetPinStyle(pin)"
                                        title="Delete pin"
                                        aria-label="Delete pin"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => SelectPinForDelete(pin.PinId)">
                                    x
                                </button>
                            }
                        }

                        @if (!_isCreatePinMode && SelectedPin is { } selectedPin)
                        {
                            <div class="map-page__pin-delete-confirm"
                                 style="@GetPinStyle(selectedPin)"
                                 @onclick:stopPropagation="true">
                                <span>Delete?</span>
                                <button type="button"
                                        class="map-page__pin-delete-confirm-button"
                                        disabled="@_isDeletingPin"
                                        @onclick="ConfirmDeleteSelectedPinAsync">
                                    @(_isDeletingPin ? "..." : "Confirm")
                                </button>
                                <button type="button"
                                        class="map-page__pin-delete-confirm-button map-page__pin-delete-confirm-button--cancel"
                                        disabled="@_isDeletingPin"
                                        @onclick="CancelDeletePinSelection">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @if (_isCreatePinDialogOpen)
                {
                    <div class="map-page__pin-popup"
                         style="@GetCreatePinPopupStyle()"
                         role="dialog"
                         aria-modal="false"
                         aria-label="Create pin popup"
                         @onclick:stopPropagation="true">
                        <div class="map-page__pin-popup-title">Create pin</div>

                        <label class="map-page__pin-popup-label" for="map-pin-name-input">Name (optional)</label>
                        <input id="map-pin-name-input"
                               class="map-page__pin-popup-input"
                               placeholder="Pin name"
                               value="@_createPinNameInput"
                               @oninput="OnCreatePinNameInput"
                               @onkeydown="OnCreatePinPopupKeyDown"
                               disabled="@_isCreatingPin"
                               autofocus
                               onfocus="this.select();" />

                        <label class="map-page__pin-popup-label" for="map-pin-article-input">Linked Article Id (optional)</label>
                        <input id="map-pin-article-input"
                               class="map-page__pin-popup-input"
                               placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                               value="@_createPinArticleIdInput"
                               @oninput="OnCreatePinArticleIdInput"
                               @onkeydown="OnCreatePinPopupKeyDown"
                               disabled="@_isCreatingPin" />

                        <div class="map-page__pin-popup-actions">
                            <button type="button"
                                    class="map-page__pin-popup-button map-page__pin-popup-button--cancel"
                                    disabled="@_isCreatingPin"
                                    @onclick="CancelCreatePinDialog">
                                Cancel
                            </button>
                            <button type="button"
                                    class="map-page__pin-popup-button"
                                    disabled="@_isCreatingPin"
                                    @onclick="ConfirmCreatePinFromDialogAsync">
                                @(_isCreatingPin ? "Creating..." : "Save")
                            </button>
                        </div>
                    </div>
                }
            </div>

            <div class="map-page__zoom-control" aria-label="Map zoom controls">
                <button type="button"
                        class="map-page__zoom-button"
                        disabled="@(!CanZoomIn())"
                        aria-label="Zoom in"
                        @onclick="ZoomInFromButton">
                    +
                </button>
                <input type="range"
                       class="map-page__zoom-slider"
                       min="0"
                       max="100"
                       step="1"
                       value="@GetZoomSliderValue()"
                       @oninput="OnZoomSliderInput"
                       disabled="@(!_hasMapViewportLayout)"
                       aria-label="Map zoom level" />
                <button type="button"
                        class="map-page__zoom-button"
                        disabled="@(!CanZoomOut())"
                        aria-label="Zoom out"
                        @onclick="ZoomOutFromButton">
                    -
                </button>
            </div>
        </div>
    </MudPaper>
}

@code {
    [Parameter]
    public Guid WorldId { get; set; }

    [Parameter]
    public Guid MapId { get; set; }

    private const double ZoomRangeSliderMax = 100d;
    private const double ZoomButtonSliderStep = 10d;
    private const double ZoomRangeMultiplier = 5d;
    private const double PanDragThresholdPx = 3d;
    private const double PanEnableZoomDelta = 0.0001d;
    private const int PolygonClickDebounceMs = 175;
    private const int MaxPolygonNameLength = 200;
    private const string DefaultPolygonColor = "blue";
    private static readonly PolygonColorOption[] PolygonColorOptions =
    [
        new("blue", "Blue", "rgb(59 130 246 / 0.35)", "rgb(30 64 175 / 0.95)", "rgb(37 99 235 / 0.46)", "rgb(29 78 216 / 1)"),
        new("green", "Green", "rgb(34 197 94 / 0.35)", "rgb(22 101 52 / 0.95)", "rgb(22 163 74 / 0.46)", "rgb(21 128 61 / 1)"),
        new("amber", "Amber", "rgb(245 158 11 / 0.35)", "rgb(146 64 14 / 0.95)", "rgb(217 119 6 / 0.46)", "rgb(180 83 9 / 1)"),
        new("red", "Red", "rgb(239 68 68 / 0.35)", "rgb(127 29 29 / 0.95)", "rgb(220 38 38 / 0.46)", "rgb(185 28 28 / 1)"),
        new("teal", "Teal", "rgb(20 184 166 / 0.35)", "rgb(19 78 74 / 0.95)", "rgb(13 148 136 / 0.46)", "rgb(15 118 110 / 1)"),
    ];
    private static readonly Dictionary<string, PolygonColorOption> PolygonColorOptionsByKey =
        PolygonColorOptions.ToDictionary(option => option.Key, StringComparer.OrdinalIgnoreCase);

    private bool _isLoading = true;
    private bool _isSavingMap;
    private bool _hasUnsavedMapChanges;
    private bool _canManageMap;
    private bool _isCreatePinMode;
    private bool _isCreatePolygonMode;
    private bool _isCreatingPin;
    private bool _isCreatingPolygon;
    private bool _isDeletingPin;
    private bool _isCreatePinDialogOpen;
    private MapDetailState _state = MapDetailState.Loaded;
    private string _worldName = "World";
    private string _mapName = "Map";
    private string _editMapName = "Map";
    private string _mapSaveError = string.Empty;
    private string _createPinError = string.Empty;
    private string _createPolygonError = string.Empty;
    private string _createPolygonStatus = string.Empty;
    private string _createPolygonColor = DefaultPolygonColor;
    private string _pinDeleteError = string.Empty;
    private string _polygonEditError = string.Empty;
    private string _addLayerError = string.Empty;
    private string _manageLayerError = string.Empty;
    private string _createLayerNameInput = string.Empty;
    private Guid? _createLayerParentLayerId;
    private bool _isInlineCreateActive;
    private string _renameLayerNameInput = string.Empty;
    private string _renameLayerOriginalName = string.Empty;
    private string _createPinArticleIdInput = string.Empty;
    private string _createPinNameInput = string.Empty;
    private string _basemapReadUrl = string.Empty;
    private float? _pendingCreatePinX;
    private float? _pendingCreatePinY;
    private float? _pendingCreatePinViewportX;
    private float? _pendingCreatePinViewportY;
    private Guid? SelectedLayerId;
    private List<MapLayerDto> _layers = [];
    private Guid? _draggedLayerId;
    private int? _dropTargetIndex;
    private List<MapPinResponseDto> _pins = [];
    private readonly Dictionary<Guid, PolygonRenderModel> _polygonsByFeatureId = [];
    private readonly PolygonDraftState _polygonDraft = new();
    private Guid? _selectedPinId;
    private Guid? _selectedPolygonFeatureId;
    private PolygonGeometry? _selectedPolygonOriginalGeometry;
    private PolygonGeometry? _selectedPolygonWorkingGeometry;
    private string _selectedPolygonOriginalName = string.Empty;
    private string _selectedPolygonName = string.Empty;
    private string _selectedPolygonOriginalColor = DefaultPolygonColor;
    private string _selectedPolygonColor = DefaultPolygonColor;
    private int? _activePolygonVertexIndex;
    private bool _isDraggingPolygonVertex;
    private bool _isSavingPolygonEdit;
    private bool _isDeletingPolygon;
    private bool _isAddingLayer;
    private bool _isRenamingLayer;
    private bool _isDeletingLayer;
    private Guid? _editingLayerId;
    private Guid? _pendingDeleteLayerId;
    private Guid? _nestingLayerId;
    private Guid? _selectedNestParentLayerId;
    private Guid? _parentChangeInFlightLayerId;
    private bool _isApplyingParentChange;
    private bool _isNestParentPickerOpen;
    private readonly HashSet<Guid> _protectedDefaultLayerIds = [];
    private readonly HashSet<Guid> _collapsedLayerIds = [];
    private readonly List<MapLayerDto> _eligibleNestParentCandidates = [];
    private readonly List<LayerRenderRow> _layerRows = [];
    private bool _hasMapViewportLayout;
    private double? _mapPreferredViewportHeightPx;
    private double _mapBaseWidth;
    private double _mapBaseHeight;
    private double _mapViewportWidth;
    private double _mapViewportHeight;
    private double _mapViewportLeft;
    private double _mapViewportTop;
    private double _mapMinZoom = 1d;
    private double _mapMaxZoom = 1d;
    private double _mapZoom = 1d;
    private double _mapPanX;
    private double _mapPanY;
    private bool _isMapPointerDown;
    private bool _isMapDragging;
    private bool _suppressCreatePinClick;
    private double _dragStartClientX;
    private double _dragStartClientY;
    private double _dragStartPanX;
    private double _dragStartPanY;
    private double _polygonVertexDragStartLocalX;
    private double _polygonVertexDragStartLocalY;
    private double _polygonVertexDragStartClientX;
    private double _polygonVertexDragStartClientY;
    private bool _hasPolygonVertexDragClientAnchor;
    private bool _shouldFocusCreateLayerInput;
    private bool _shouldFocusRenameLayerInput;
    private bool _shouldFocusMapViewport;
    private NormalizedMapPoint? _polygonHoverPoint;
    private string _polygonDraftPathData = string.Empty;
    private CancellationTokenSource? _pendingPolygonClickCts;
    private NormalizedMapPoint? _pendingPolygonClickPoint;
    private ElementReference _createLayerInputRef;
    private ElementReference _renameLayerInputRef;
    private ElementReference _mapViewportRef;
    private ElementReference _mapImageRef;
    private IJSObjectReference? _mapInteropModule;
    private DotNetObjectReference<MapDetail>? _dotNetRef;
    private List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/dashboard"),
        new("World", href: null, disabled: true),
        new("Maps", href: null, disabled: true),
        new("Map", href: null, disabled: true)
    ];

    private enum MapDetailState
    {
        Loaded,
        NotFound,
        Unauthorized,
        BasemapMissing,
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusCreateLayerInput && _isInlineCreateActive)
        {
            _shouldFocusCreateLayerInput = false;

            try
            {
                await _createLayerInputRef.FocusAsync();
            }
            catch (JSException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }

        if (_shouldFocusRenameLayerInput && _editingLayerId.HasValue)
        {
            _shouldFocusRenameLayerInput = false;

            try
            {
                await _renameLayerInputRef.FocusAsync();
            }
            catch (JSException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }

        if (_shouldFocusMapViewport && _isCreatePolygonMode)
        {
            _shouldFocusMapViewport = false;

            try
            {
                await _mapViewportRef.FocusAsync();
            }
            catch (JSException)
            {
            }
            catch (InvalidOperationException)
            {
            }
        }
    }

