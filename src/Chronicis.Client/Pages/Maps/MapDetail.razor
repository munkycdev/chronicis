    private async Task CompletePolygonDraftAsync()
    {
        if (!SelectedLayerId.HasValue)
        {
            _createPolygonError = "Select a layer before saving a polygon.";
            _createPolygonStatus = string.Empty;
            Logger.LogWarning("Map {MapId}: polygon completion blocked because no layer is selected.", MapId);
            return;
        }

        if (!IsSelectedLayerEffectivelyVisible)
        {
            _createPolygonError = "Selected layer is hidden. Enable the layer (and ancestors) before saving a polygon.";
            _createPolygonStatus = string.Empty;
            Logger.LogWarning(
                "Map {MapId}: polygon completion blocked because selected layer {SelectedLayerId} is hidden by visibility inheritance.",
                MapId,
                SelectedLayerId.Value);
            return;
        }

        if (!_polygonDraft.CanComplete)
        {
            _createPolygonError = "Polygon requires at least 3 distinct vertices.";
            _createPolygonStatus = string.Empty;
            Logger.LogWarning(
                "Map {MapId}: polygon completion blocked because draft has insufficient distinct vertices. DraftVertices={DraftVertexCount}.",
                MapId,
                _polygonDraft.Vertices.Count);
            return;
        }

        var polygon = _polygonDraft.BuildClosedPolygon();
        if (!polygon.IsClosed || polygon.Vertices.Any(vertex => !vertex.IsInBounds))
        {
            _createPolygonError = "Polygon geometry is invalid.";
            _createPolygonStatus = string.Empty;
            Logger.LogWarning("Map {MapId}: polygon completion blocked because geometry validation failed.", MapId);
            return;
        }

        var selectedLayerLabel = GetSelectedLayerLabel();
        _createPolygonStatus = $"Saving polygon to layer '{selectedLayerLabel}'...";
        Logger.LogInformation(
            "Map {MapId}: saving polygon. Layer={SelectedLayer}, VertexCount={VertexCount}.",
            MapId,
            selectedLayerLabel,
            polygon.Vertices.Count);
        _isCreatingPolygon = true;

        try
        {
            var created = await MapApi.CreateFeatureAsync(
                WorldId,
                MapId,
                new MapFeatureCreateDto
                {
                    FeatureType = MapFeatureType.Polygon,
                    LayerId = SelectedLayerId.Value,
                    Color = _createPolygonColor,
                    Polygon = GeoJsonPolygonSerializer.ToDto(polygon),
                });

            if (created == null || !TrySetRenderedPolygon(created))
            {
                _createPolygonError = "Failed to create polygon.";
                _createPolygonStatus = "Polygon save did not return a renderable feature.";
                Logger.LogWarning("Map {MapId}: polygon save returned null or non-renderable result.", MapId);
                return;
            }

            _createPolygonError = string.Empty;
            _createPolygonStatus = $"Polygon saved to '{selectedLayerLabel}'.";
            Logger.LogInformation(
                "Map {MapId}: polygon created. FeatureId={FeatureId}, LayerId={LayerId}.",
                MapId,
                created.FeatureId,
                created.LayerId);
            SelectPolygon(created.FeatureId);
            ClearPolygonDraft();
        }
        catch (Exception ex)
        {
            _createPolygonError = $"Failed to create polygon: {ex.Message}";
            _createPolygonStatus = "Polygon save failed.";
            Logger.LogError(ex, "Map {MapId}: polygon save failed.", MapId);
        }
        finally
        {
            _isCreatingPolygon = false;
        }
    }

    private string GetSelectedLayerLabel() =>
        SelectedLayer?.Name ?? SelectedLayerId?.ToString() ?? "none";

    private bool TrySetRenderedPolygon(MapFeatureDto feature)
    {
        if (feature.Polygon == null)
        {
            return false;
        }

        if (feature.MapId != MapId
            || feature.FeatureType != MapFeatureType.Polygon
            || !PolygonSvgPathBuilder.TryBuildPath(feature.Polygon, out var pathData))
        {
            return false;
        }

        var geometry = GeoJsonPolygonSerializer.FromDto(feature.Polygon);
        _polygonsByFeatureId[feature.FeatureId] = new PolygonRenderModel(
            feature.FeatureId,
            feature.LayerId,
            feature.Name ?? string.Empty,
            feature.LinkedArticleId,
            geometry,
            pathData,
            NormalizePolygonColorKey(feature.Color));

        return true;
    }

    private bool TrySelectPolygonAtPoint(MouseEventArgs args)
    {
        if (_isCreatePinMode || _isCreatePolygonMode || IsPolygonEditInteractionLocked)
        {
            return false;
        }

        if (!TryGetMapPoint(args, out var point))
        {
            return false;
        }

        if (TryInsertVertexIntoSelectedPolygonAtPoint(point))
        {
            return true;
        }

        var polygon = GetVisiblePolygons()
            .Reverse()
            .FirstOrDefault(candidate => PolygonHitTester.ContainsPoint(candidate.Geometry, point));

        if (polygon == null)
        {
            ClearPolygonEditState();
            return false;
        }

        SelectPolygon(polygon.FeatureId);
        return true;
    }

    private bool TryInsertVertexIntoSelectedPolygonAtPoint(NormalizedMapPoint point)
    {
        if (SelectedPolygonRenderModel is not { } polygon
            || _selectedPolygonWorkingGeometry == null)
        {
            return false;
        }

        if (PolygonVertexEditor.FindNearestVertexIndex(
                _selectedPolygonWorkingGeometry,
                point,
                GetPolygonVertexSelectionThreshold()) >= 0)
        {
            return false;
        }

        if (!PolygonVertexEditor.TryInsertVertex(
                _selectedPolygonWorkingGeometry,
                point,
                GetPolygonEdgeSelectionThreshold(),
                out var updatedGeometry,
                out _))
        {
            return false;
        }

        ResetPolygonVertexDragState();
        _selectedPolygonWorkingGeometry = updatedGeometry;
        _polygonEditError = string.Empty;
        SetPolygonRenderGeometry(
            polygon.FeatureId,
            polygon.LayerId,
            _selectedPolygonName,
            polygon.LinkedArticleId,
            updatedGeometry,
            _selectedPolygonColor);
        StateHasChanged();
        return true;
    }

    private void SelectPolygon(Guid featureId)
    {
        if (!_polygonsByFeatureId.TryGetValue(featureId, out var polygon))
        {
            ClearPolygonEditState();
            return;
        }

        _polygonEditError = string.Empty;
        _selectedPolygonFeatureId = polygon.FeatureId;
        _selectedPolygonOriginalGeometry = polygon.Geometry;
        _selectedPolygonWorkingGeometry = polygon.Geometry;
        _selectedPolygonOriginalName = polygon.DisplayName;
        _selectedPolygonName = _selectedPolygonOriginalName;
        _selectedPolygonOriginalColor = NormalizePolygonColorKey(polygon.Color);
        _selectedPolygonColor = _selectedPolygonOriginalColor;
        ResetPolygonVertexDragState();
        StateHasChanged();
    }

    private void ClearPolygonEditState()
    {
        var hadSelection =
            _selectedPolygonFeatureId.HasValue
            || _selectedPolygonOriginalGeometry != null
            || _selectedPolygonWorkingGeometry != null
            || !string.IsNullOrEmpty(_selectedPolygonOriginalName)
            || !string.IsNullOrEmpty(_selectedPolygonName)
            || !string.Equals(_selectedPolygonColor, DefaultPolygonColor, StringComparison.Ordinal)
            || !string.Equals(_selectedPolygonOriginalColor, DefaultPolygonColor, StringComparison.Ordinal)
            || _activePolygonVertexIndex.HasValue
            || _isDraggingPolygonVertex;

        _polygonEditError = string.Empty;
        _selectedPolygonFeatureId = null;
        _selectedPolygonOriginalGeometry = null;
        _selectedPolygonWorkingGeometry = null;
        _selectedPolygonOriginalName = string.Empty;
        _selectedPolygonName = string.Empty;
        _selectedPolygonOriginalColor = DefaultPolygonColor;
        _selectedPolygonColor = DefaultPolygonColor;
        ResetPolygonVertexDragState();

        if (hadSelection)
        {
            StateHasChanged();
        }
    }

    private void CancelSelectedPolygonEdit()
    {
        if (SelectedPolygonRenderModel is not { } polygon || _selectedPolygonOriginalGeometry == null)
        {
            ClearPolygonEditState();
            return;
        }

        _selectedPolygonWorkingGeometry = _selectedPolygonOriginalGeometry;
        _selectedPolygonName = _selectedPolygonOriginalName;
        _selectedPolygonColor = _selectedPolygonOriginalColor;
        SetPolygonRenderGeometry(
            polygon.FeatureId,
            polygon.LayerId,
            _selectedPolygonOriginalName,
            polygon.LinkedArticleId,
            _selectedPolygonOriginalGeometry,
            _selectedPolygonOriginalColor);
    }

    private async Task SaveSelectedPolygonAsync()
    {
        if (SelectedPolygonRenderModel is not { } polygon
            || _selectedPolygonWorkingGeometry == null
            || IsPolygonEditInteractionLocked)
        {
            return;
        }

        if (!TryValidateSelectedPolygon(_selectedPolygonWorkingGeometry, out var validationError))
        {
            _polygonEditError = validationError;
            return;
        }

        _polygonEditError = string.Empty;
        _isSavingPolygonEdit = true;

        try
        {
            var updated = await MapApi.UpdateFeatureAsync(
                WorldId,
                MapId,
                polygon.FeatureId,
                new MapFeatureUpdateDto
                {
                    Name = string.IsNullOrWhiteSpace(_selectedPolygonName) ? null : _selectedPolygonName.Trim(),
                    Color = _selectedPolygonColor,
                    LayerId = polygon.LayerId,
                    LinkedArticleId = polygon.LinkedArticleId,
                    Polygon = GeoJsonPolygonSerializer.ToDto(_selectedPolygonWorkingGeometry),
                });

            if (updated == null || !TrySetRenderedPolygon(updated))
            {
                _polygonEditError = "Failed to save polygon.";
                return;
            }

            SelectPolygon(updated.FeatureId);
        }
        catch (Exception ex)
        {
            _polygonEditError = $"Failed to save polygon: {ex.Message}";
        }
        finally
        {
            _isSavingPolygonEdit = false;
        }
    }

    private async Task DeleteSelectedPolygonAsync()
    {
        if (SelectedPolygonRenderModel is not { } polygon || IsPolygonEditInteractionLocked)
        {
            return;
        }

        _polygonEditError = string.Empty;
        _isDeletingPolygon = true;

        try
        {
            var deleted = await MapApi.DeleteFeatureAsync(WorldId, MapId, polygon.FeatureId);
            if (!deleted)
            {
                _polygonEditError = "Failed to delete polygon.";
                return;
            }

            _polygonsByFeatureId.Remove(polygon.FeatureId);
            ClearPolygonEditState();
        }
        finally
        {
            _isDeletingPolygon = false;
        }
    }

    private bool TryValidateSelectedPolygon(PolygonGeometry geometry, out string validationError)
    {
        validationError = string.Empty;
        if (!geometry.IsClosed)
        {
            validationError = "Polygon geometry is invalid.";
            return false;
        }

        if (geometry.Vertices.Any(vertex => !vertex.IsInBounds))
        {
            validationError = "Polygon geometry is invalid.";
            return false;
        }

        var distinctVertexCount = geometry.Vertices.Take(geometry.Vertices.Count - 1).Distinct().Count();
        if (distinctVertexCount < 3)
        {
            validationError = "Polygon requires at least 3 distinct vertices.";
            return false;
        }

        return true;
    }

    private bool TryBeginPolygonVertexDrag(MouseEventArgs args)
    {
        if (SelectedPolygonRenderModel is not { } polygon
            || _selectedPolygonWorkingGeometry == null
            || _isCreatePolygonMode
            || _isCreatePinMode
            || IsPolygonEditInteractionLocked
            || !TryGetMapPointForVertexDrag(args, out var point))
        {
            return false;
        }

        var threshold = GetPolygonVertexSelectionThreshold();
        var vertexIndex = PolygonVertexEditor.FindNearestVertexIndex(_selectedPolygonWorkingGeometry, point, threshold);
        if (vertexIndex < 0)
        {
            return false;
        }

        return BeginPolygonVertexDrag(vertexIndex, args);
    }

    private void OnPolygonVertexMouseDown(MouseEventArgs args, int vertexIndex)
    {
        if (args.Button != 0
            || SelectedPolygonRenderModel is not { }
            || _selectedPolygonWorkingGeometry == null
            || _isCreatePolygonMode
            || _isCreatePinMode
            || IsPolygonEditInteractionLocked
            || vertexIndex < 0
            || vertexIndex >= GetEditablePolygonVertices(_selectedPolygonWorkingGeometry).Count())
        {
            return;
        }

        BeginPolygonVertexDrag(vertexIndex, args);
    }

    private bool BeginPolygonVertexDrag(int vertexIndex, MouseEventArgs args)
    {
        if (_selectedPolygonWorkingGeometry == null
            || vertexIndex < 0
            || vertexIndex >= _selectedPolygonWorkingGeometry.Vertices.Count
            || !TryGetViewportLocalPoint(_selectedPolygonWorkingGeometry.Vertices[vertexIndex], out var localX, out var localY))
        {
            return false;
        }

        _activePolygonVertexIndex = vertexIndex;
        _isDraggingPolygonVertex = true;
        _isMapPointerDown = false;
        _isMapDragging = false;
        _polygonVertexDragStartLocalX = localX;
        _polygonVertexDragStartLocalY = localY;
        _polygonVertexDragStartClientX = HasClientViewportCoordinates(args)
            ? args.ClientX
            : _mapViewportLeft + localX;
        _polygonVertexDragStartClientY = HasClientViewportCoordinates(args)
            ? args.ClientY
            : _mapViewportTop + localY;
        _hasPolygonVertexDragClientAnchor = HasClientViewportCoordinates(args);
        _polygonEditError = string.Empty;
        return true;
    }

    private void UpdateSelectedPolygonVertex(MouseEventArgs args)
    {
        if (_activePolygonVertexIndex is not { } vertexIndex
            || SelectedPolygonRenderModel is not { } polygon
            || _selectedPolygonWorkingGeometry == null
            || !TryGetMapPointForActiveVertexDrag(args, out var point))
        {
            return;
        }

        if (!PolygonVertexEditor.TryMoveVertex(_selectedPolygonWorkingGeometry, vertexIndex, point, out var updatedGeometry))
        {
            return;
        }

        _selectedPolygonWorkingGeometry = updatedGeometry;
        SetPolygonRenderGeometry(
            polygon.FeatureId,
            polygon.LayerId,
            _selectedPolygonName,
            polygon.LinkedArticleId,
            updatedGeometry,
            _selectedPolygonColor);
        StateHasChanged();
    }

    private void SetPolygonRenderGeometry(
        Guid featureId,
        Guid layerId,
        string displayName,
        Guid? linkedArticleId,
        PolygonGeometry geometry,
        string color)
    {
        var dto = GeoJsonPolygonSerializer.ToDto(geometry);
        if (!PolygonSvgPathBuilder.TryBuildPath(dto, out var pathData))
        {
            return;
        }

        _polygonsByFeatureId[featureId] = new PolygonRenderModel(
            featureId,
            layerId,
            displayName,
            linkedArticleId,
            geometry,
            pathData,
            NormalizePolygonColorKey(color));
    }

    private void ReconcileSelectedPolygonState()
    {
        if (!_selectedPolygonFeatureId.HasValue)
        {
            return;
        }

        if (!_polygonsByFeatureId.ContainsKey(_selectedPolygonFeatureId.Value)
            || SelectedPolygonRenderModel == null)
        {
            ClearPolygonEditState();
        }
    }

    private bool TryGetMapPoint(MouseEventArgs args, out NormalizedMapPoint point)
    {
        if (TryGetMapPointFromOffsets(args, out point))
        {
            return true;
        }

        return TryGetMapPointFromClientViewportCoordinates(args, out point);
    }

    private bool TryGetMapPointForVertexDrag(MouseEventArgs args, out NormalizedMapPoint point)
    {
        if (TryGetMapPointFromClientViewportCoordinates(args, out point))
        {
            return true;
        }

        return TryGetMapPointFromOffsets(args, out point);
    }

    private bool TryGetMapPointForActiveVertexDrag(MouseEventArgs args, out NormalizedMapPoint point)
    {
        if (_hasPolygonVertexDragClientAnchor)
        {
            point = default;
            if (!HasClientViewportCoordinates(args))
            {
                return false;
            }

            var localX = _polygonVertexDragStartLocalX + (args.ClientX - _polygonVertexDragStartClientX);
            var localY = _polygonVertexDragStartLocalY + (args.ClientY - _polygonVertexDragStartClientY);
            return MapViewportCoordinateConverter.TryConvertToNormalizedPoint(
                localX,
                localY,
                _mapViewportWidth,
                _mapViewportHeight,
                _mapBaseWidth,
                _mapBaseHeight,
                _mapPanX,
                _mapPanY,
                _mapZoom,
                out point);
        }

        return TryGetMapPointFromOffsets(args, out point);
    }

    private bool TryGetViewportLocalPoint(NormalizedMapPoint point, out double localX, out double localY)
    {
        localX = 0d;
        localY = 0d;

        if (_mapBaseWidth <= 0d || _mapBaseHeight <= 0d || _mapZoom <= 0d)
        {
            return false;
        }

        localX = (point.X * _mapBaseWidth * _mapZoom) + _mapPanX;
        localY = (point.Y * _mapBaseHeight * _mapZoom) + _mapPanY;
        return true;
    }

    private void ResetPolygonVertexDragState()
    {
        _activePolygonVertexIndex = null;
        _isDraggingPolygonVertex = false;
        _polygonVertexDragStartLocalX = 0d;
        _polygonVertexDragStartLocalY = 0d;
        _polygonVertexDragStartClientX = 0d;
        _polygonVertexDragStartClientY = 0d;
        _hasPolygonVertexDragClientAnchor = false;
    }

    private bool TryGetMapPointFromClientViewportCoordinates(MouseEventArgs args, out NormalizedMapPoint point)
    {
        point = default;
        return HasClientViewportCoordinates(args)
            && MapViewportCoordinateConverter.TryConvertToNormalizedPoint(
                args.ClientX - _mapViewportLeft,
                args.ClientY - _mapViewportTop,
                _mapViewportWidth,
                _mapViewportHeight,
                _mapBaseWidth,
                _mapBaseHeight,
                _mapPanX,
                _mapPanY,
                _mapZoom,
                out point);
    }

    private bool TryGetMapPointFromOffsets(MouseEventArgs args, out NormalizedMapPoint point) =>
        MapViewportCoordinateConverter.TryConvertToNormalizedPoint(
            args.OffsetX,
            args.OffsetY,
            _mapViewportWidth,
            _mapViewportHeight,
            _mapBaseWidth,
            _mapBaseHeight,
            _mapPanX,
            _mapPanY,
            _mapZoom,
            out point);

    private bool HasClientViewportCoordinates(MouseEventArgs args) =>
        _mapViewportWidth > 0d
        && _mapViewportHeight > 0d
        && (args.ClientX != 0d || args.ClientY != 0d);

