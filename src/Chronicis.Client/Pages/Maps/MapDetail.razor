        }
        else if (!IsEditingLayer(layerRow.Layer.MapLayerId))
        {
            <div class="map-page__layer-actions">
                <button type="button"
                        class="map-page__layer-action-button map-page__layer-add-child-button"
                        @onclick:stopPropagation="true"
                        @onclick="() => BeginAddChildLayer(layerRow.Layer.MapLayerId)"
                        disabled="@(!CanBeginInlineLayerCreate(layerRow.Layer.MapLayerId))">
                    Add Child Layer
                </button>
            </div>
        }
    </div>;

    private RenderFragment RenderInlineCreateRow(int createDepth) => @<div class="map-page__layer-row map-page__layer-row--inline-create"
         data-layer-depth="@createDepth">
        <span class="map-page__layer-depth-spacer"
              style="@GetLayerDepthStyle(createDepth)"
              aria-hidden="true"></span>
        <span class="map-page__layer-drag-handle" aria-hidden="true"></span>
        <span class="map-page__layer-create-spacer" aria-hidden="true"></span>
        <input type="text"
               class="map-page__layer-create-input"
               @ref="_createLayerInputRef"
               value="@_createLayerNameInput"
               @onclick:stopPropagation="true"
               @oninput="OnCreateLayerNameInput"
               @onkeydown="OnCreateLayerNameKeyDown"
               disabled="@_isAddingLayer" />
        <div class="map-page__layer-actions">
            <button type="button"
                    class="map-page__layer-action-button"
                    @onclick:stopPropagation="true"
                    @onclick="SaveCreatedLayerAsync"
                    disabled="@_isAddingLayer">
                @(_isAddingLayer ? "Saving..." : "Save")
            </button>
            <button type="button"
                    class="map-page__layer-action-button map-page__layer-action-button--cancel"
                    @onclick:stopPropagation="true"
                    @onclick="CancelInlineLayerCreate"
                    disabled="@_isAddingLayer">
                Cancel
            </button>
        </div>
    </div>;

    private string GetLayerRowClass(LayerRenderRow layerRow, IReadOnlySet<Guid> effectivelyVisibleLayerIds) =>
        $"map-page__layer-row map-page__layer-row--hoverable {(effectivelyVisibleLayerIds.Contains(layerRow.Layer.MapLayerId) ? "map-page__layer-row--enabled" : "map-page__layer-row--disabled")} {(SelectedLayerId == layerRow.Layer.MapLayerId ? "layer-row-selected" : string.Empty)} {(_draggedLayerId == layerRow.Layer.MapLayerId ? "map-page__layer-row--dragging" : string.Empty)} {(_dropTargetIndex == layerRow.FlatIndex ? "map-page__layer-row--drop-target" : string.Empty)}";

    private void SetLayerExpandedState(Guid layerId, bool expanded)
    {
        var row = _layerRows.FirstOrDefault(existingRow => existingRow.Layer.MapLayerId == layerId);
        if (row == null || !row.HasChildren || (!expanded && row.IsCollapseBlocked))
        {
            return;
        }

        if (expanded)
        {
            _collapsedLayerIds.Remove(layerId);
        }
        else
        {
            _collapsedLayerIds.Add(layerId);
        }

        RebuildLayerRows();
    }

    private void BeginLayerRename(Guid layerId)
    {
        if (!CanBeginLayerRename(layerId))
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == layerId);
        if (layer == null)
        {
            return;
        }

        ExpandAncestorChain(layerId, includeSelf: false);
        _editingLayerId = layerId;
        _renameLayerNameInput = layer.Name;
        _renameLayerOriginalName = layer.Name;
        _shouldFocusRenameLayerInput = true;
        _manageLayerError = string.Empty;
        _pendingDeleteLayerId = null;
        CancelNestLayer();
    }

    private void OnRenameLayerNameInput(ChangeEventArgs args)
    {
        if (_isRenamingLayer)
        {
            return;
        }

        _renameLayerNameInput = args.Value?.ToString() ?? string.Empty;
        _manageLayerError = string.Empty;
    }

    private Task OnRenameLayerNameKeyDown(Guid layerId, KeyboardEventArgs args)
    {
        if (_isRenamingLayer)
        {
            return Task.CompletedTask;
        }

        if (string.Equals(args.Key, "Enter", StringComparison.Ordinal))
        {
            return ConfirmLayerRenameAsync(layerId);
        }

        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            CancelLayerRename();
        }

        return Task.CompletedTask;
    }

    private void CancelLayerRename()
    {
        if (_isRenamingLayer)
        {
            return;
        }

        ClearLayerRenameState();
    }

    private void ClearLayerRenameState()
    {
        _editingLayerId = null;
        _renameLayerNameInput = string.Empty;
        _renameLayerOriginalName = string.Empty;
        _shouldFocusRenameLayerInput = false;
    }

    private async Task ConfirmLayerRenameAsync(Guid layerId)
    {
        if (_isRenamingLayer || !IsEditingLayer(layerId) || IsProtectedDefaultLayer(layerId))
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == layerId);
        if (layer == null)
        {
            return;
        }

        var nextName = (_renameLayerNameInput ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(nextName))
        {
            _manageLayerError = "Layer name is required.";
            return;
        }

        if (nextName.Length > 200)
        {
            _manageLayerError = "Layer name must be 200 characters or fewer.";
            return;
        }

        if (string.Equals(nextName, _renameLayerOriginalName, StringComparison.Ordinal))
        {
            ClearLayerRenameState();
            return;
        }

        _isRenamingLayer = true;
        _manageLayerError = string.Empty;

        try
        {
            await MapApi.RenameLayerAsync(WorldId, MapId, layerId, nextName);
            layer.Name = nextName;
            ClearLayerRenameState();
        }
        catch (Exception ex)
        {
            _manageLayerError = $"Failed to rename layer: {ex.Message}";
        }
        finally
        {
            _isRenamingLayer = false;
        }
    }

    private void BeginLayerDelete(Guid layerId)
    {
        if (IsProtectedDefaultLayer(layerId))
        {
            return;
        }

        _pendingDeleteLayerId = layerId;
        _manageLayerError = string.Empty;
        ClearLayerRenameState();
        CancelNestLayer();
    }

    private void CancelLayerDelete()
    {
        _pendingDeleteLayerId = null;
        _isDeletingLayer = false;
    }

    private async Task ConfirmLayerDeleteAsync(Guid layerId)
    {
        if (_isDeletingLayer || !IsPendingDeleteLayer(layerId) || IsProtectedDefaultLayer(layerId))
        {
            return;
        }

        _isDeletingLayer = true;
        _manageLayerError = string.Empty;

        try
        {
            await MapApi.DeleteLayerAsync(WorldId, MapId, layerId);
            _layers.RemoveAll(layer => layer.MapLayerId == layerId);
            RebuildLayerRows();
            ClearNestLayerStateIfTargetMissing(layerId);

            if (SelectedLayerId == layerId)
            {
                SelectedLayerId = _layers.FirstOrDefault()?.MapLayerId;
            }
        }
        catch (Exception ex)
        {
            _manageLayerError = $"Failed to delete layer: {ex.Message}";
        }
        finally
        {
            _isDeletingLayer = false;
            _pendingDeleteLayerId = null;
        }
    }

    private void BeginNestLayer(Guid layerId)
    {
        if (_isApplyingParentChange || _parentChangeInFlightLayerId.HasValue || IsProtectedDefaultLayer(layerId))
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == layerId);
        if (layer == null)
        {
            return;
        }

        _nestingLayerId = layerId;
        _selectedNestParentLayerId = null;
        _manageLayerError = string.Empty;
        ClearLayerRenameState();
        _pendingDeleteLayerId = null;
        _isNestParentPickerOpen = true;
        _eligibleNestParentCandidates.Clear();
        _eligibleNestParentCandidates.AddRange(GetEligibleNestParentCandidates(layer));
    }

    private void CancelNestLayer()
    {
        _isNestParentPickerOpen = false;
        _nestingLayerId = null;
        _selectedNestParentLayerId = null;
        _eligibleNestParentCandidates.Clear();
        _isApplyingParentChange = false;
    }

    private void OnNestParentSelectionChanged(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        _selectedNestParentLayerId = Guid.TryParse(value, out var parentId) ? parentId : null;
    }

    private async Task ConfirmNestLayerAsync()
    {
        if (!_isNestParentPickerOpen || !_nestingLayerId.HasValue || !_selectedNestParentLayerId.HasValue || _isApplyingParentChange)
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == _nestingLayerId.Value);
        if (layer == null)
        {
            CancelNestLayer();
            return;
        }

        var selectedParentId = _selectedNestParentLayerId.Value;
        var isValidCandidate = _eligibleNestParentCandidates.Any(candidate => candidate.MapLayerId == selectedParentId);
        if (!isValidCandidate || layer.ParentLayerId == selectedParentId)
        {
            return;
        }

        await ApplyLayerParentChangeAsync(layer.MapLayerId, selectedParentId, closeNestDialogOnSuccess: true);
    }

    private async Task MoveLayerToRootAsync(Guid layerId)
    {
        if (_isApplyingParentChange || _parentChangeInFlightLayerId.HasValue || IsProtectedDefaultLayer(layerId))
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == layerId);
        if (layer == null || layer.ParentLayerId == null)
        {
            return;
        }

        await ApplyLayerParentChangeAsync(layerId, null, closeNestDialogOnSuccess: false);
    }

    private async Task ApplyLayerParentChangeAsync(Guid layerId, Guid? parentLayerId, bool closeNestDialogOnSuccess)
    {
        if (_isApplyingParentChange || _parentChangeInFlightLayerId.HasValue)
        {
            return;
        }

        var layer = _layers.FirstOrDefault(existingLayer => existingLayer.MapLayerId == layerId);
        if (layer == null || layer.ParentLayerId == parentLayerId)
        {
            return;
        }

        _isApplyingParentChange = true;
        _parentChangeInFlightLayerId = layerId;
        _manageLayerError = string.Empty;

        try
        {
            await MapApi.SetLayerParentAsync(WorldId, MapId, layerId, parentLayerId);
            layer.ParentLayerId = parentLayerId;
            RebuildLayerRows();

            if (closeNestDialogOnSuccess)
            {
                CancelNestLayer();
            }
        }
        catch (Exception ex)
        {
            _manageLayerError = $"Failed to move layer: {ex.Message}";
        }
        finally
        {
            _isApplyingParentChange = false;
            _parentChangeInFlightLayerId = null;
        }
    }

    private IEnumerable<MapLayerDto> GetEligibleNestParentCandidates(MapLayerDto layer)
    {
        var descendantIds = GetDescendantLayerIds(layer.MapLayerId);

        return _layers
            .Where(candidate => candidate.MapLayerId != layer.MapLayerId)
            .Where(candidate => !descendantIds.Contains(candidate.MapLayerId))
            .Where(candidate => candidate.MapLayerId != layer.ParentLayerId)
            .OrderBy(candidate => candidate.SortOrder)
            .ThenBy(candidate => candidate.Name, StringComparer.Ordinal)
            .ThenBy(candidate => candidate.MapLayerId);
    }

    private HashSet<Guid> GetDescendantLayerIds(Guid layerId)
    {
        var descendants = new HashSet<Guid>();
        var visited = new HashSet<Guid> { layerId };
        var queue = new Queue<Guid>();
        queue.Enqueue(layerId);

        while (queue.Count > 0)
        {
            var currentId = queue.Dequeue();
            var childIds = _layers
                .Where(layer => layer.ParentLayerId == currentId)
                .Select(layer => layer.MapLayerId);

            foreach (var childId in childIds)
            {
                if (!visited.Add(childId))
                {
                    continue;
                }

                descendants.Add(childId);
                queue.Enqueue(childId);
            }
        }

        return descendants;
    }

    private void OnLayerDragStart(Guid layerId, DragEventArgs args)
    {
        _draggedLayerId = layerId;
        _dropTargetIndex = _layers.FindIndex(l => l.MapLayerId == layerId);

        if (args.DataTransfer is null)
        {
            return;
        }

        args.DataTransfer.DropEffect = "move";
        args.DataTransfer.EffectAllowed = "move";
    }

    private void OnLayerDragEnter(int targetIndex)
    {
        if (!_draggedLayerId.HasValue)
        {
            return;
        }

        _dropTargetIndex = targetIndex;
    }

    private void OnLayerDragOver(int targetIndex)
    {
        if (!_draggedLayerId.HasValue)
        {
            return;
        }

        _dropTargetIndex = targetIndex;
    }

    private async Task OnLayerDropAsync(int targetIndex)
    {
        if (!_draggedLayerId.HasValue)
        {
            ClearLayerDragState();
            return;
        }

        var draggedLayerId = _draggedLayerId.Value;
        var draggedIndex = _layers.FindIndex(l => l.MapLayerId == draggedLayerId);
        if (draggedIndex < 0 || targetIndex < 0 || targetIndex >= _layers.Count || draggedIndex == targetIndex)
        {
            ClearLayerDragState();
            return;
        }

        var draggedLayer = _layers[draggedIndex];
        var targetLayer = _layers[targetIndex];
        if (draggedLayer.ParentLayerId != targetLayer.ParentLayerId)
        {
            ClearLayerDragState();
            return;
        }

        var previousLayerOrder = _layers
            .Select(layer => layer.MapLayerId)
            .ToList();

        if (!TryReorderSiblingGroup(_layers, draggedIndex, targetIndex, out var reorderedSiblingLayerIds))
        {
            ClearLayerDragState();
            return;
        }

        RebuildLayerRows();
        StateHasChanged();

        try
        {
            await MapApi.ReorderLayersAsync(WorldId, MapId, reorderedSiblingLayerIds);
        }
        catch
        {
            _layers = RestoreLayerOrder(_layers, previousLayerOrder);
            RebuildLayerRows();
            StateHasChanged();
        }
        finally
        {
            ClearLayerDragState();
        }
    }

    private void OnLayerDragEnd(DragEventArgs _) => ClearLayerDragState();

    private void ClearLayerDragState()
    {
        _draggedLayerId = null;
        _dropTargetIndex = null;
    }

    private static void MoveLayer(List<MapLayerDto> layers, int fromIndex, int toIndex)
    {
        var movedLayer = layers[fromIndex];
        layers.RemoveAt(fromIndex);
        layers.Insert(toIndex, movedLayer);
    }

    private static bool TryReorderSiblingGroup(
        List<MapLayerDto> allLayers,
        int draggedIndex,
        int targetIndex,
        out List<Guid> reorderedSiblingLayerIds)
    {
        reorderedSiblingLayerIds = [];

        if (draggedIndex < 0 || draggedIndex >= allLayers.Count || targetIndex < 0 || targetIndex >= allLayers.Count)
        {
            return false;
        }

        var parentLayerId = allLayers[draggedIndex].ParentLayerId;
        if (allLayers[targetIndex].ParentLayerId != parentLayerId)
        {
            return false;
        }

        var siblingIndices = Enumerable.Range(0, allLayers.Count)
            .Where(index => allLayers[index].ParentLayerId == parentLayerId)
            .ToList();
        var draggedSiblingIndex = siblingIndices.IndexOf(draggedIndex);
        var targetSiblingIndex = siblingIndices.IndexOf(targetIndex);
        if (draggedSiblingIndex < 0 || targetSiblingIndex < 0 || draggedSiblingIndex == targetSiblingIndex)
        {
            return false;
        }

        var siblings = siblingIndices
            .Select(index => allLayers[index])
            .ToList();
        MoveLayer(siblings, draggedSiblingIndex, targetSiblingIndex);

        for (var index = 0; index < siblingIndices.Count; index++)
        {
            allLayers[siblingIndices[index]] = siblings[index];
        }

        reorderedSiblingLayerIds = siblings
            .Select(layer => layer.MapLayerId)
            .ToList();
        return true;
    }

    private static List<MapLayerDto> RestoreLayerOrder(List<MapLayerDto> currentLayers, IReadOnlyList<Guid> orderedLayerIds)
    {
        var layersById = currentLayers.ToDictionary(layer => layer.MapLayerId);
        var restored = orderedLayerIds
            .Where(layersById.ContainsKey)
            .Select(layerId => layersById[layerId])
            .ToList();

        if (restored.Count < currentLayers.Count)
        {
            restored.AddRange(currentLayers.Where(layer => !orderedLayerIds.Contains(layer.MapLayerId)));
        }

        return restored;
    }

    private void RebuildLayerRows()
    {
        _layerRows.Clear();
        if (_layers.Count == 0)
        {
            _collapsedLayerIds.Clear();
            ClearInlineLayerCreateStateIfParentMissing();
            return;
        }

        var childrenByParentId = _layers
            .Where(layer => layer.ParentLayerId.HasValue)
            .GroupBy(layer => layer.ParentLayerId!.Value)
            .ToDictionary(
                group => group.Key,
                group => group
                    .OrderBy(layer => layer.SortOrder)
                    .ThenBy(layer => layer.Name, StringComparer.Ordinal)
                    .ThenBy(layer => layer.MapLayerId)
                    .ToList());

        var visited = new HashSet<Guid>();
        var flatIndexByLayerId = _layers
            .Select((layer, index) => new { layer.MapLayerId, Index = index })
            .ToDictionary(item => item.MapLayerId, item => item.Index);
        var activeEditAncestorIds = GetAncestorLayerIds(_editingLayerId, includeSelf: false);
        var activeCreateAncestorIds = GetAncestorLayerIds(_createLayerParentLayerId, includeSelf: true);

        var rootLayers = _layers
            .Where(layer => !layer.ParentLayerId.HasValue || !_layers.Any(candidate => candidate.MapLayerId == layer.ParentLayerId.Value))
            .OrderBy(layer => layer.SortOrder)
            .ThenBy(layer => layer.Name, StringComparer.Ordinal)
            .ThenBy(layer => layer.MapLayerId);

        foreach (var rootLayer in rootLayers)
        {
            BuildLayerRowsDepthFirst(
                rootLayer,
                depth: 0,
                areAncestorsExpanded: true,
                childrenByParentId,
                flatIndexByLayerId,
                activeEditAncestorIds,
                activeCreateAncestorIds,
                visited);
        }

        foreach (var remainingLayer in _layers
                     .Where(layer => !visited.Contains(layer.MapLayerId))
                     .OrderBy(layer => layer.SortOrder)
                     .ThenBy(layer => layer.Name, StringComparer.Ordinal)
                     .ThenBy(layer => layer.MapLayerId))
        {
            BuildLayerRowsDepthFirst(
                remainingLayer,
                depth: 0,
                areAncestorsExpanded: true,
                childrenByParentId,
                flatIndexByLayerId,
                activeEditAncestorIds,
                activeCreateAncestorIds,
                visited);
        }

        PruneCollapsedLayerIds();
        ClearInlineLayerCreateStateIfParentMissing();
    }

    private void BuildLayerRowsDepthFirst(
        MapLayerDto layer,
        int depth,
        bool areAncestorsExpanded,
        IReadOnlyDictionary<Guid, List<MapLayerDto>> childrenByParentId,
        IReadOnlyDictionary<Guid, int> flatIndexByLayerId,
        ISet<Guid> activeEditAncestorIds,
        ISet<Guid> activeCreateAncestorIds,
        HashSet<Guid> visited)
    {
        if (!visited.Add(layer.MapLayerId))
        {
            return;
        }

        var hasChildren = childrenByParentId.ContainsKey(layer.MapLayerId);
        var isCollapsed = hasChildren && _collapsedLayerIds.Contains(layer.MapLayerId);
        var isCollapseBlocked = activeEditAncestorIds.Contains(layer.MapLayerId)
            || activeCreateAncestorIds.Contains(layer.MapLayerId);

        if (areAncestorsExpanded)
        {
            _layerRows.Add(new LayerRenderRow(
                layer,
                depth,
                flatIndexByLayerId[layer.MapLayerId],
                hasChildren,
                isCollapsed,
                isCollapseBlocked));
        }

        if (!hasChildren || !childrenByParentId.TryGetValue(layer.MapLayerId, out var children))
        {
            return;
        }

        var showChildren = areAncestorsExpanded && !isCollapsed;
        foreach (var child in children)
        {
            BuildLayerRowsDepthFirst(
                child,
                depth + 1,
                showChildren,
                childrenByParentId,
                flatIndexByLayerId,
                activeEditAncestorIds,
                activeCreateAncestorIds,
                visited);
        }
    }

    private static string GetLayerDepthStyle(int depth)
    {
        var clampedDepth = depth < 0 ? 0 : depth;
        var indentPixels = clampedDepth * 14;
        return string.Create(CultureInfo.InvariantCulture, $"display:inline-block;width:{indentPixels}px;");
    }

    private void ClearInlineLayerCreateStateIfParentMissing()
    {
        if (!_isInlineCreateActive || !_createLayerParentLayerId.HasValue)
        {
            return;
        }

        if (_layers.Any(layer => layer.MapLayerId == _createLayerParentLayerId.Value))
        {
            return;
        }

        ClearInlineLayerCreateState();
    }

    private void ExpandAncestorChain(Guid layerId, bool includeSelf)
    {
        foreach (var ancestorLayerId in GetAncestorLayerIds(layerId, includeSelf))
        {
            _collapsedLayerIds.Remove(ancestorLayerId);
        }
    }

    private HashSet<Guid> GetAncestorLayerIds(Guid? layerId, bool includeSelf)
    {
        var ancestorLayerIds = new HashSet<Guid>();
        if (!layerId.HasValue)
        {
            return ancestorLayerIds;
        }

        var layersById = _layers.ToDictionary(layer => layer.MapLayerId);
        var visited = new HashSet<Guid>();
        Guid? currentLayerId = includeSelf
            ? layerId.Value
            : layersById.TryGetValue(layerId.Value, out var layer) ? layer.ParentLayerId : null;

        while (currentLayerId.HasValue && visited.Add(currentLayerId.Value))
        {
            ancestorLayerIds.Add(currentLayerId.Value);
            if (!layersById.TryGetValue(currentLayerId.Value, out var currentLayer) || !currentLayer.ParentLayerId.HasValue)
            {
                break;
            }

            currentLayerId = currentLayer.ParentLayerId;
        }

        return ancestorLayerIds;
    }

    private void PruneCollapsedLayerIds()
    {
        if (_collapsedLayerIds.Count == 0)
        {
            return;
        }

        var validLayerIds = _layers.Select(layer => layer.MapLayerId).ToHashSet();
        _collapsedLayerIds.RemoveWhere(layerId => !validLayerIds.Contains(layerId));
    }

    private void ClearNestLayerStateIfTargetMissing(Guid removedLayerId)
    {
        if (_nestingLayerId == removedLayerId)
        {
            CancelNestLayer();
            return;
        }

        if (_selectedNestParentLayerId == removedLayerId)
        {
            _selectedNestParentLayerId = null;
        }

        _eligibleNestParentCandidates.RemoveAll(candidate => candidate.MapLayerId == removedLayerId);
    }

    private IEnumerable<MapPinResponseDto> GetVisiblePins()
    {
        if (_layers.Count == 0)
        {
            return _pins;
        }

        var layerOrderById = _layers
            .Select((layer, index) => new { layer.MapLayerId, Index = index })
            .ToDictionary(x => x.MapLayerId, x => x.Index);

        var enabledLayerIds = GetEffectivelyVisibleLayerIds();

        return _pins
            .Select((pin, index) => new { Pin = pin, Index = index })
            .Where(x => enabledLayerIds.Contains(x.Pin.LayerId))
            .OrderBy(x => layerOrderById[x.Pin.LayerId])
            .ThenBy(x => x.Index)
            .Select(x => x.Pin);
    }

    private IEnumerable<PolygonRenderModel> GetVisiblePolygons()
    {
        if (_polygonsByFeatureId.Count == 0)
        {
            return [];
        }

        var layerOrderById = _layers
            .Select((layer, index) => new { layer.MapLayerId, Index = index })
            .ToDictionary(x => x.MapLayerId, x => x.Index);

        var enabledLayerIds = GetEffectivelyVisibleLayerIds();

        return _polygonsByFeatureId.Values
            .Where(polygon => enabledLayerIds.Contains(polygon.LayerId))
            .OrderBy(polygon => layerOrderById.TryGetValue(polygon.LayerId, out var order) ? order : int.MaxValue)
            .ThenBy(polygon => polygon.DisplayName, StringComparer.Ordinal)
            .ThenBy(polygon => polygon.FeatureId);
    }

    private void SetRenderedPolygons(IEnumerable<MapFeatureDto>? features)
    {
        _polygonsByFeatureId.Clear();

        if (features == null)
        {
            return;
        }

        foreach (var feature in features)
        {
            TrySetRenderedPolygon(feature);
        }
    }

    private HashSet<Guid> GetEffectivelyVisibleLayerIds() =>
        MapLayerVisibilityEvaluator.GetEffectivelyVisibleLayerIds(_layers);

    private MapLayerDto? SelectedLayer =>
        SelectedLayerId.HasValue
            ? _layers.FirstOrDefault(layer => layer.MapLayerId == SelectedLayerId.Value)
            : null;

    private bool IsSelectedLayerEffectivelyVisible =>
        SelectedLayerId.HasValue && GetEffectivelyVisibleLayerIds().Contains(SelectedLayerId.Value);

    private async Task OnLayerVisibilityChangedAsync(Guid layerId, ChangeEventArgs args)
    {
        var layer = _layers.FirstOrDefault(l => l.MapLayerId == layerId);
        if (layer == null)
        {
            return;
        }

        var isEnabled = args.Value switch
        {
            bool boolValue => boolValue,
            string stringValue when bool.TryParse(stringValue, out var parsed) => parsed,
            _ => layer.IsEnabled,
        };

        if (isEnabled == layer.IsEnabled)
        {
            return;
        }

        await MapApi.UpdateLayerVisibilityAsync(WorldId, MapId, layerId, isEnabled);
        layer.IsEnabled = isEnabled;
        ReconcileSelectedPolygonState();
    }

