        _isCreatePolygonMode
            ? "Click to add vertices. Use Save or double-click to close and save. Backspace removes the last point. Escape cancels."
            : _isCreatePinMode
                ? "Click on the map to choose pin details."
                : SelectedPolygonRenderModel != null
                    ? "Drag polygon vertices. Escape cancels unsaved edits."
                    : "Enable Create Pin or Create Polygon, then click the map.";

    private string GetCreatePolygonEditorStatus()
    {
        var vertexCount = _polygonDraft.Vertices.Count + (_pendingPolygonClickPoint.HasValue ? 1 : 0);
        if (vertexCount == 0)
        {
            return "Draft: click map to add points";
        }

        if (vertexCount < 3)
        {
            return $"Draft: {vertexCount}/3 points";
        }

        return $"Draft: {vertexCount} points";
    }

    private static string NormalizePolygonColorKey(string? value) =>
        GetPolygonColorOption(value).Key;

    private static PolygonColorOption GetPolygonColorOption(string? value)
    {
        if (!string.IsNullOrWhiteSpace(value)
            && PolygonColorOptionsByKey.TryGetValue(value.Trim(), out var option))
        {
            return option;
        }

        return PolygonColorOptions[0];
    }

    private bool ShouldPreventMapViewportKeyDefault =>
        _isCreatePolygonMode || SelectedPolygonRenderModel != null;

    private PolygonRenderModel? SelectedPolygonRenderModel =>
        _selectedPolygonFeatureId.HasValue
        && _polygonsByFeatureId.TryGetValue(_selectedPolygonFeatureId.Value, out var polygon)
        && GetEffectivelyVisibleLayerIds().Contains(polygon.LayerId)
            ? polygon
            : null;

    private bool IsSelectedPolygonDirty =>
        (_selectedPolygonOriginalGeometry != null
            && _selectedPolygonWorkingGeometry != null
            && !_selectedPolygonOriginalGeometry.Vertices.SequenceEqual(_selectedPolygonWorkingGeometry.Vertices))
        || !string.Equals(_selectedPolygonOriginalName, _selectedPolygonName, StringComparison.Ordinal)
        || !string.Equals(_selectedPolygonOriginalColor, _selectedPolygonColor, StringComparison.Ordinal);

    private bool IsPolygonEditInteractionLocked =>
        _isSavingPolygonEdit || _isDeletingPolygon;

