    private Task OnMapViewportKeyDown(KeyboardEventArgs args)
    {
        if (!_isCreatePolygonMode)
        {
            if (string.Equals(args.Key, "Escape", StringComparison.Ordinal) && IsSelectedPolygonDirty)
            {
                _polygonEditError = string.Empty;
                CancelSelectedPolygonEdit();
            }

            return Task.CompletedTask;
        }

        if (string.Equals(args.Key, "Escape", StringComparison.Ordinal))
        {
            _createPolygonError = string.Empty;
            ClearPolygonDraft();
            return Task.CompletedTask;
        }

        if (string.Equals(args.Key, "Backspace", StringComparison.Ordinal))
        {
            _createPolygonError = string.Empty;

            if (_pendingPolygonClickPoint.HasValue)
            {
                CancelPendingPolygonClick();
            }
            else
            {
                _polygonDraft.RemoveLastVertex();
            }

            UpdatePolygonDraftPreview();
        }

        return Task.CompletedTask;
    }

