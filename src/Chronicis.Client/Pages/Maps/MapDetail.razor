            $"left:{point.X * 100:F4}%;top:{point.Y * 100:F4}%;");

    private static bool TryGetPolygonLabelPosition(PolygonGeometry geometry, out NormalizedMapPoint point)
    {
        point = default;

        if (geometry.Vertices.Count < 3)
        {
            return false;
        }

        var vertices = geometry.IsClosed && geometry.Vertices.Count > 1
            ? geometry.Vertices.Take(geometry.Vertices.Count - 1).ToList()
            : geometry.Vertices.ToList();

        if (vertices.Count < 3)
        {
            return false;
        }

        double areaTwice = 0d;
        double centroidXAccumulator = 0d;
        double centroidYAccumulator = 0d;

        for (var i = 0; i < vertices.Count; i++)
        {
            var current = vertices[i];
            var next = vertices[(i + 1) % vertices.Count];
            var cross = (current.X * next.Y) - (next.X * current.Y);
            areaTwice += cross;
            centroidXAccumulator += (current.X + next.X) * cross;
            centroidYAccumulator += (current.Y + next.Y) * cross;
        }

        if (Math.Abs(areaTwice) > 1e-7)
        {
            var centroidX = centroidXAccumulator / (3d * areaTwice);
            var centroidY = centroidYAccumulator / (3d * areaTwice);
            point = new NormalizedMapPoint((float)Math.Clamp(centroidX, 0d, 1d), (float)Math.Clamp(centroidY, 0d, 1d));
            return true;
        }

        var minX = vertices.Min(vertex => vertex.X);
        var maxX = vertices.Max(vertex => vertex.X);
        var minY = vertices.Min(vertex => vertex.Y);
        var maxY = vertices.Max(vertex => vertex.Y);
        point = new NormalizedMapPoint((minX + maxX) / 2f, (minY + maxY) / 2f);
        return true;
    }

    private IEnumerable<(int Index, NormalizedMapPoint Point)> GetEditablePolygonVertices(PolygonGeometry geometry)
    {
        var count = geometry.IsClosed && geometry.Vertices.Count > 1
            ? geometry.Vertices.Count - 1
            : geometry.Vertices.Count;

        for (var i = 0; i < count; i++)
        {
            yield return (i, geometry.Vertices[i]);
        }
    }

    private string GetPolygonVertexClass(int vertexIndex) =>
        _activePolygonVertexIndex == vertexIndex
            ? "map-page__polygon-vertex map-page__polygon-vertex--active"
            : "map-page__polygon-vertex";

    private float GetPolygonVertexSelectionThreshold()
    {
        var baseDimension = Math.Max(Math.Min(_mapBaseWidth, _mapBaseHeight), 1d);
        // Vertex markers live inside the scaled map stage, so the hit radius should track
        // their on-screen growth instead of shrinking as zoom increases.
        var normalizedThreshold = 14d / baseDimension;
        return (float)normalizedThreshold;
    }

    private float GetPolygonEdgeSelectionThreshold()
    {
        var baseDimension = Math.Max(Math.Min(_mapBaseWidth, _mapBaseHeight), 1d);
        var normalizedThreshold = 10d / baseDimension;
        return (float)normalizedThreshold;
    }

    private bool TryGetPolygonDraftPoint(MouseEventArgs args, out NormalizedMapPoint point) =>
        TryGetMapPoint(args, out point);

    private void UpdatePolygonHoverPoint(MouseEventArgs args)
    {
        if (TryGetPolygonDraftPoint(args, out var point))
        {
            _polygonHoverPoint = point;
        }
        else
        {
            _polygonHoverPoint = null;
        }

        UpdatePolygonDraftPreview();
    }

    private void UpdatePolygonDraftPreview()
    {
        var hoverPoint = _isCreatePolygonMode ? _polygonHoverPoint : null;
        _polygonDraftPathData = PolygonSvgPathBuilder.TryBuildDraftPath(_polygonDraft.Vertices, hoverPoint, out var pathData)
            ? pathData
            : string.Empty;
    }

    private void SchedulePolygonVertexAdd(NormalizedMapPoint point)
    {
        CancelPendingPolygonClick();
        _pendingPolygonClickPoint = point;
        _pendingPolygonClickCts = new CancellationTokenSource();
        _ = CommitPendingPolygonVertexAsync(_pendingPolygonClickCts.Token);
    }

    private async Task CommitPendingPolygonVertexAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(PolygonClickDebounceMs, cancellationToken);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        if (cancellationToken.IsCancellationRequested || !_pendingPolygonClickPoint.HasValue)
        {
            return;
        }

        FlushPendingPolygonClick();
        await InvokeAsync(StateHasChanged);
    }

    private void FlushPendingPolygonClick()
    {
        var point = _pendingPolygonClickPoint;
        CancelPendingPolygonClick();

        if (!point.HasValue)
        {
            return;
        }

        _polygonDraft.AddVertex(point.Value);
        UpdatePolygonDraftPreview();
    }

    private void CancelPendingPolygonClick()
    {
        if (_pendingPolygonClickCts != null)
        {
            _pendingPolygonClickCts.Cancel();
            _pendingPolygonClickCts.Dispose();
            _pendingPolygonClickCts = null;
        }

        _pendingPolygonClickPoint = null;
    }

    private void ClearPolygonDraft()
    {
        CancelPendingPolygonClick();
        _polygonDraft.Clear();
        _polygonHoverPoint = null;
        _polygonDraftPathData = string.Empty;
    }

    private void ExitPolygonMode()
    {
        _isCreatePolygonMode = false;
        ClearPolygonDraft();
    }

