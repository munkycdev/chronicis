    private static string GetPinLabelStyle(MapPinResponseDto pin) =>
        $"left:{pin.X * 100:F4}%;top:{pin.Y * 100:F4}%;";

    private static bool HasPinLabel(MapPinResponseDto pin) =>
        !string.IsNullOrWhiteSpace(pin.Name);

    private static string GetPinTooltip(MapPinResponseDto pin)
    {
        if (!string.IsNullOrWhiteSpace(pin.Name))
        {
            return pin.Name;
        }

        if (pin.LinkedArticle is not null)
        {
            return pin.LinkedArticle.Title;
        }

        return "Map pin";
    }

    private string GetFeaturePointClass(MapFeatureDto feature) =>
        feature.FeatureId == _highlightedFeatureId
            ? "session-map-viewer-modal__feature-point session-map-viewer-modal__feature-point--highlighted"
            : "session-map-viewer-modal__feature-point";

    private static string GetFeaturePointStyle(MapFeatureDto feature) =>
        $"left:{feature.Point!.X * 100:F4}%;top:{feature.Point.Y * 100:F4}%;";

    private string GetFeaturePolygonClass(MapFeatureDto feature) =>
        feature.FeatureId == _highlightedFeatureId
            ? "session-map-viewer-modal__feature-polygon session-map-viewer-modal__feature-polygon--highlighted"
            : "session-map-viewer-modal__feature-polygon";

    private static string GetFeaturePolygonPoints(MapFeatureDto feature) =>
        string.Join(
            " ",
            feature.Polygon!.Coordinates[0].Select(point =>
                string.Create(CultureInfo.InvariantCulture, $"{point[0] * 100:F4},{point[1] * 100:F4}")));

    private static string GetFeatureTooltip(MapFeatureDto feature) =>
        !string.IsNullOrWhiteSpace(feature.Name)
            ? feature.Name
            : feature.LinkedArticle?.Title ?? "Map feature";

