@using System.Globalization
@using Chronicis.Client.Utilities
@using Chronicis.Shared.DTOs.Maps
@using Chronicis.Shared.Enums
@inject IMapApiService MapApi
@inject IPublicApiService PublicApi
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (IsOpen)
{
    <div class="session-map-viewer-modal__backdrop" @onclick="CloseAsync">
        <section class="session-map-viewer-modal"
                 @onclick:stopPropagation="true"
                 role="dialog"
                 aria-modal="true"
                 aria-label="Map viewer"
                 tabindex="0"
                 autofocus
                 @onkeydown="HandleKeyDown">
            <header class="session-map-viewer-modal__header">
                <MudText Typo="Typo.h6" Class="session-map-viewer-modal__title">
                    @ViewerTitle
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               aria-label="Close map viewer"
                               Class="session-map-viewer-modal__close"
                               OnClick="CloseAsync" />
            </header>

            <div class="session-map-viewer-modal__content">
                @if (_isLoading)
                {
                    <div class="session-map-viewer-modal__state">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Class="mt-3">Loading map...</MudText>
                    </div>
                }
                else if (_state == SessionMapViewerState.Unauthorized)
                {
                    <MudAlert Severity="Severity.Error">You do not have access to this map.</MudAlert>
                }
                else if (_state == SessionMapViewerState.NotFound)
                {
                    <MudAlert Severity="Severity.Error">Map not found.</MudAlert>
                }
                else if (_state == SessionMapViewerState.BasemapMissing)
                {
                    <MudAlert Severity="Severity.Warning">Basemap is missing for this map.</MudAlert>
                }
                else if (_state == SessionMapViewerState.Loaded)
                {
                    <div class="session-map-viewer-modal__layout">
                        <aside class="session-map-viewer-modal__layers" aria-label="Map layers">
                            @{
                                var effectivelyVisibleLayerIds = GetLocallyVisibleLayerIds();
                                var layerTreeRoots = BuildLayerTreeRoots();
                            }
                            @if (layerTreeRoots.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Class="session-map-viewer-modal__layers-empty">
                                    No layers available.
                                </MudText>
                            }
                            else
                            {
                                <MudTreeView T="Guid"
                                             Hover="true"
                                             Dense="true"
                                             ReadOnly="true"
                                             Ripple="false"
                                             ExpandOnClick="false"
                                             Class="session-map-viewer-modal__layer-tree">
                                    @foreach (var layerTreeRoot in layerTreeRoots)
                                    {
                                        @RenderLayerTreeItem(layerTreeRoot, effectivelyVisibleLayerIds)
                                    }
                                </MudTreeView>
                            }
                        </aside>

                        <div class="session-map-viewer-modal__image-shell">
                            <div @ref="_mapViewportRef"
                                 class="@GetMapViewportClass()"
                                 @onmousedown="OnMapViewportMouseDown"
                                 @onmousemove="OnMapViewportMouseMove"
                                 @onmouseup="OnMapViewportMouseUp"
                                 @onmouseleave="OnMapViewportMouseUp"
>
                                <div class="session-map-viewer-modal__map-stage" style="@GetMapStageStyle()">
                                    <img @ref="_mapImageRef"
                                         src="@_basemapReadUrl"
                                         alt="@ViewerTitle"
                                         class="@GetMapImageClass()"
                                         @onload="OnMapImageLoaded"
                                         draggable="false" />
                                    <div class="session-map-viewer-modal__features-overlay" aria-hidden="true">
                                        @foreach (var feature in GetVisibleFeatures())
                                        {
                                            if (feature.FeatureType == MapFeatureType.Point && feature.Point is not null)
                                            {
                                                <div class="@GetFeaturePointClass(feature)"
                                                     style="@GetFeaturePointStyle(feature)"
                                                     title="@GetFeatureTooltip(feature)">
                                                </div>
                                            }
                                            else if (feature.FeatureType == MapFeatureType.Polygon && feature.Polygon is not null)
                                            {
                                                <svg class="@GetFeaturePolygonClass(feature)" viewBox="0 0 100 100" preserveAspectRatio="none">
                                                    <polygon points="@GetFeaturePolygonPoints(feature)" />
                                                </svg>
                                            }
                                        }
                                    </div>
                                    <div class="session-map-viewer-modal__pins-overlay" aria-hidden="true">
                                        @foreach (var pin in GetVisiblePins())
                                        {
                                            <div class="session-map-viewer-modal__pin"
                                                 style="@GetPinStyle(pin)"
                                                 title="@GetPinTooltip(pin)">
                                            </div>

                                            @if (HasPinLabel(pin))
                                            {
                                                <div class="session-map-viewer-modal__pin-name"
                                                     style="@GetPinLabelStyle(pin)"
                                                     title="@pin.Name">
                                                    @pin.Name
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="session-map-viewer-modal__zoom-control" aria-label="Map zoom controls">
                                <button type="button"
                                        class="session-map-viewer-modal__zoom-button"
                                        disabled="@(!CanZoomIn())"
                                        aria-label="Zoom in"
                                        @onclick="ZoomInFromButton">
                                    +
                                </button>
                                <input type="range"
                                       class="session-map-viewer-modal__zoom-slider"
                                       min="0"
                                       max="100"
                                       step="1"
                                       value="@GetZoomSliderValue()"
                                       @oninput="OnZoomSliderInput"
                                       disabled="@(!_hasMapViewportLayout)"
                                       aria-label="Map zoom level" />
                                <button type="button"
                                        class="session-map-viewer-modal__zoom-button"
                                        disabled="@(!CanZoomOut())"
                                        aria-label="Zoom out"
                                        @onclick="ZoomOutFromButton">
                                    -
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>
}

@code {
    private bool _lastIsOpen;
    private bool _isLoading;
    private string _basemapReadUrl = string.Empty;
    private List<MapPinResponseDto> _pins = [];
    private List<MapFeatureDto> _features = [];
    private List<MapLayerDto> _layers = [];
    private SessionMapViewerState _state;
    private Guid _activeWorldId;
    private Guid _activeMapId;
    private Guid? _activeTargetFeatureId;
    private bool _hasActiveTarget;
    private bool _targetFocusPending;
    private Guid? _highlightedFeatureId;
    private int _loadVersion;
    private const double ZoomRangeSliderMax = 100d;
    private const double ZoomButtonSliderStep = 10d;
    private const double ZoomRangeMultiplier = 5d;
    private const double ZoomWheelSliderStep = 4d;
    private const double PanDragThresholdPx = 3d;
    private const double PanEnableZoomDelta = 0.0001d;
    private bool _hasMapViewportLayout;
    private double _mapBaseWidth;
    private double _mapBaseHeight;
    private double _mapViewportWidth;
    private double _mapViewportHeight;
    private double _mapMinZoom = 1d;
    private double _mapMaxZoom = 1d;
    private double _mapZoom = 1d;
    private double _mapPanX;
    private double _mapPanY;
    private bool _isMapPointerDown;
    private bool _isMapDragging;
    private double _dragStartClientX;
    private double _dragStartClientY;
    private double _dragStartPanX;
    private double _dragStartPanY;
    private ElementReference _mapViewportRef;
    private ElementReference _mapImageRef;
    private IJSObjectReference? _mapInteropModule;
    private DotNetObjectReference<SessionMapViewerModal>? _dotNetRef;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public Guid WorldId { get; set; }

    [Parameter]
    public Guid MapId { get; set; }

    [Parameter]
    public Guid? TargetFeatureId { get; set; }

    [Parameter]
    public string? MapName { get; set; }

    [Parameter]
    public string? PublicSlug { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            _lastIsOpen = false;
            return;
        }

        var modalJustOpened = !_lastIsOpen;
        var targetChangedWhileOpen = _lastIsOpen
            && (!_hasActiveTarget || _activeWorldId != WorldId || _activeMapId != MapId || _activeTargetFeatureId != TargetFeatureId);

        if (modalJustOpened || targetChangedWhileOpen)
        {
            _activeWorldId = WorldId;
            _activeMapId = MapId;
            _activeTargetFeatureId = TargetFeatureId;
            _hasActiveTarget = true;
            await LoadBasemapAsync(WorldId, MapId);
        }

        _lastIsOpen = true;
    }

    private async Task LoadBasemapAsync(Guid worldId, Guid mapId)
    {
        var requestVersion = ++_loadVersion;
        _isLoading = true;
        _basemapReadUrl = string.Empty;
        _pins = [];
        _features = [];
        _layers = [];
        _highlightedFeatureId = null;
        _targetFocusPending = TargetFeatureId.HasValue;
        ResetMapViewportState();
        _state = SessionMapViewerState.None;
        await InvokeAsync(StateHasChanged);

        var basemapResult = IsPublicMode
            ? await PublicApi.GetPublicMapBasemapReadUrlAsync(PublicSlug!, mapId)
            : await MapApi.GetBasemapReadUrlAsync(worldId, mapId);
        if (requestVersion != _loadVersion || !IsOpen || WorldId != worldId || MapId != mapId)
        {
            return;
        }

        if (IsUnauthorized(basemapResult.StatusCode))
        {
            _state = SessionMapViewerState.Unauthorized;
        }
        else if (IsBasemapMissing(basemapResult.StatusCode, basemapResult.Error))
        {
            _state = SessionMapViewerState.BasemapMissing;
        }
        else if (basemapResult.StatusCode == 404)
        {
            _state = SessionMapViewerState.NotFound;
        }
        else if (string.IsNullOrWhiteSpace(basemapResult.Basemap?.ReadUrl))
        {
            _state = SessionMapViewerState.BasemapMissing;
        }
        else
        {
            _basemapReadUrl = basemapResult.Basemap.ReadUrl;
            var layers = await TryLoadLayersAsync(worldId, mapId);
            var pins = await TryLoadPinsAsync(worldId, mapId);
            var features = await TryLoadFeaturesAsync(worldId, mapId);
            if (requestVersion != _loadVersion || !IsOpen || WorldId != worldId || MapId != mapId)
            {
                return;
            }

            _layers = layers;
            _pins = pins;
            _features = features;
            _state = SessionMapViewerState.Loaded;
        }

        _isLoading = false;
    }

    private async Task<List<MapPinResponseDto>> TryLoadPinsAsync(Guid worldId, Guid mapId)
    {
        try
        {
            var pinsTask = IsPublicMode
                ? PublicApi.GetPublicMapPinsAsync(PublicSlug!, mapId)
                : MapApi.ListPinsForMapAsync(worldId, mapId);
            if (pinsTask is null)
            {
                return [];
            }

            return await pinsTask ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task<List<MapFeatureDto>> TryLoadFeaturesAsync(Guid worldId, Guid mapId)
    {
        try
        {
            var featuresTask = IsPublicMode
                ? PublicApi.GetPublicMapFeaturesAsync(PublicSlug!, mapId)
                : MapApi.ListFeaturesForMapAsync(worldId, mapId);
            if (featuresTask is null)
            {
                return [];
            }

            return await featuresTask ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task<List<MapLayerDto>> TryLoadLayersAsync(Guid worldId, Guid mapId)
    {
        try
        {
            var layersTask = IsPublicMode
                ? PublicApi.GetPublicMapLayersAsync(PublicSlug!, mapId)
                : MapApi.GetLayersForMapAsync(worldId, mapId);
            if (layersTask is null)
            {
                return [];
            }

            return await layersTask ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task OnLayerToggleChangedAsync(Guid layerId, ChangeEventArgs args)
    {
        var layerIndex = _layers.FindIndex(layer => layer.MapLayerId == layerId);
        if (layerIndex < 0 || !TryReadBool(args.Value, out var isEnabled))
        {
            return;
        }

        if (_layers[layerIndex].IsEnabled == isEnabled)
        {
            return;
        }

        if (IsPublicMode)
        {
            _layers[layerIndex].IsEnabled = isEnabled;
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            await MapApi.UpdateLayerVisibilityAsync(WorldId, MapId, layerId, isEnabled);
            _layers[layerIndex].IsEnabled = isEnabled;
        }
        catch
        {
            // Keep local state unchanged when update fails.
        }
    }

    private string GetMapViewportClass()
    {
        if (_isMapDragging)
        {
            return "session-map-viewer-modal__viewport session-map-viewer-modal__viewport--dragging";
        }

        if (CanPanMap())
        {
            return "session-map-viewer-modal__viewport session-map-viewer-modal__viewport--pan";
        }

        return "session-map-viewer-modal__viewport";
    }

    private string GetMapStageStyle()
    {
        if (!_hasMapViewportLayout)
        {
            return "width:100%;height:auto;transform:translate(0px,0px) scale(1);";
        }

        return string.Create(
            CultureInfo.InvariantCulture,
            $"width:{_mapBaseWidth:F2}px;height:{_mapBaseHeight:F2}px;transform:translate({_mapPanX:F2}px,{_mapPanY:F2}px) scale({_mapZoom:F4});");
    }

    private string GetMapImageClass() =>
        _hasMapViewportLayout
            ? "session-map-viewer-modal__image session-map-viewer-modal__image--stage"
            : "session-map-viewer-modal__image";

    private int GetZoomSliderValue() =>
        GetSliderValueForZoom(_mapZoom, _mapMinZoom, _mapMaxZoom);

    private Task OnZoomSliderInput(ChangeEventArgs args)
    {
        if (!_hasMapViewportLayout || !TryReadDouble(args.Value, out var sliderValue))
        {
            return Task.CompletedTask;
        }

        var clampedSliderValue = Clamp(sliderValue, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(clampedSliderValue, _mapMinZoom, _mapMaxZoom));
        return Task.CompletedTask;
    }

    private bool CanZoomIn() =>
        _hasMapViewportLayout
        && _mapZoom < _mapMaxZoom - PanEnableZoomDelta;

    private bool CanZoomOut() =>
        _hasMapViewportLayout
        && _mapZoom > _mapMinZoom + PanEnableZoomDelta;

    private void ZoomInFromButton()
    {
        if (!CanZoomIn())
        {
            return;
        }

        var nextSliderValue = Clamp(GetZoomSliderValue() + ZoomButtonSliderStep, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(nextSliderValue, _mapMinZoom, _mapMaxZoom));
    }

    private void ZoomOutFromButton()
    {
        if (!CanZoomOut())
        {
            return;
        }

        var nextSliderValue = Clamp(GetZoomSliderValue() - ZoomButtonSliderStep, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(nextSliderValue, _mapMinZoom, _mapMaxZoom));
    }


    private void OnMapViewportMouseDown(MouseEventArgs args)
    {
        if (args.Button != 0 || !CanPanMap())
        {
            return;
        }

        _isMapPointerDown = true;
        _isMapDragging = false;
        _dragStartClientX = args.ClientX;
        _dragStartClientY = args.ClientY;
        _dragStartPanX = _mapPanX;
        _dragStartPanY = _mapPanY;
    }

    private void OnMapViewportMouseMove(MouseEventArgs args)
    {
        if (!_isMapPointerDown)
        {
            return;
        }

        var deltaX = args.ClientX - _dragStartClientX;
        var deltaY = args.ClientY - _dragStartClientY;

        if (!_isMapDragging && Math.Abs(deltaX) < PanDragThresholdPx && Math.Abs(deltaY) < PanDragThresholdPx)
        {
            return;
        }

        _isMapDragging = true;
        _mapPanX = _dragStartPanX + deltaX;
        _mapPanY = _dragStartPanY + deltaY;
        ClampPanToBounds();
    }

    private void OnMapViewportMouseUp(MouseEventArgs _)
    {
        _isMapPointerDown = false;
        _isMapDragging = false;
    }

    private async Task OnMapImageLoaded()
    {
        await InitializeMapViewportLayoutAsync();
    }

    private async Task InitializeMapViewportLayoutAsync()
    {
        var viewportRect = await GetElementRectAsync(_mapViewportRef);
        var imageRect = await GetElementRectAsync(_mapImageRef);

        if (!HasUsableBounds(viewportRect) || !HasUsableBounds(imageRect))
        {
            return;
        }

        _mapViewportWidth = viewportRect!.Width;
        _mapViewportHeight = viewportRect.Height;
        _mapBaseWidth = imageRect!.Width;
        _mapBaseHeight = imageRect.Height;

        if (_mapBaseWidth <= 0d || _mapBaseHeight <= 0d || _mapViewportWidth <= 0d || _mapViewportHeight <= 0d)
        {
            _hasMapViewportLayout = false;
            return;
        }

        _mapMinZoom = Math.Min(_mapViewportWidth / _mapBaseWidth, _mapViewportHeight / _mapBaseHeight);
        _mapMaxZoom = Math.Max(_mapMinZoom, _mapMinZoom * ZoomRangeMultiplier);
        _mapZoom = _mapMinZoom;
        _hasMapViewportLayout = true;
        RecenterMapPan();
        FocusTargetFeatureIfNeeded();
        await SetupWheelInterceptorAsync();
    }

    private async Task SetupWheelInterceptorAsync()
    {
        try
        {
            var module = await EnsureModuleAsync();
            if (module == null) return;
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("setupWheelInterceptor", _mapViewportRef, _dotNetRef);
        }
        catch (JSException) { }
    }

    [JSInvokable]
    public void OnWheelZoom(double deltaY)
    {
        if (!_hasMapViewportLayout) return;
        var step = deltaY < 0d ? ZoomWheelSliderStep : -ZoomWheelSliderStep;
        var nextSliderValue = Clamp(GetZoomSliderValue() + step, 0d, ZoomRangeSliderMax);
        SetZoomLevel(GetZoomForSliderValue(nextSliderValue, _mapMinZoom, _mapMaxZoom));
        InvokeAsync(StateHasChanged);
    }

    private bool CanPanMap() =>
        _hasMapViewportLayout
        && _mapZoom > _mapMinZoom + PanEnableZoomDelta;

    private void SetZoomLevel(double targetZoom)
    {
        if (!_hasMapViewportLayout)
        {
            return;
        }

        var nextZoom = Clamp(targetZoom, _mapMinZoom, _mapMaxZoom);
        if (Math.Abs(nextZoom - _mapZoom) < PanEnableZoomDelta)
        {
            return;
        }

        var centerX = _mapViewportWidth / 2d;
        var centerY = _mapViewportHeight / 2d;
        var mapCenterX = (centerX - _mapPanX) / _mapZoom;
        var mapCenterY = (centerY - _mapPanY) / _mapZoom;

        _mapZoom = nextZoom;
        _mapPanX = centerX - (mapCenterX * _mapZoom);
        _mapPanY = centerY - (mapCenterY * _mapZoom);
        ClampPanToBounds();
    }

    private void RecenterMapPan()
    {
        var scaledWidth = _mapBaseWidth * _mapZoom;
        var scaledHeight = _mapBaseHeight * _mapZoom;

        _mapPanX = (_mapViewportWidth - scaledWidth) / 2d;
        _mapPanY = (_mapViewportHeight - scaledHeight) / 2d;
        ClampPanToBounds();
    }

    private void ClampPanToBounds()
    {
        var scaledWidth = _mapBaseWidth * _mapZoom;
        var scaledHeight = _mapBaseHeight * _mapZoom;
        _mapPanX = ClampPanAxis(_mapPanX, _mapViewportWidth, scaledWidth);
        _mapPanY = ClampPanAxis(_mapPanY, _mapViewportHeight, scaledHeight);
    }

    private static double ClampPanAxis(double pan, double viewportSize, double scaledSize)
    {
        if (viewportSize <= 0d || scaledSize <= 0d)
        {
            return 0d;
        }

        if (scaledSize <= viewportSize)
        {
            return (viewportSize - scaledSize) / 2d;
        }

        return Clamp(pan, viewportSize - scaledSize, 0d);
    }

    private static int GetSliderValueForZoom(double zoom, double minZoom, double maxZoom)
    {
        if (maxZoom <= minZoom)
        {
            return 0;
        }

        var normalized = (zoom - minZoom) / (maxZoom - minZoom);
        return (int)Math.Round(Clamp(normalized * ZoomRangeSliderMax, 0d, ZoomRangeSliderMax), MidpointRounding.AwayFromZero);
    }

    private static double GetZoomForSliderValue(double sliderValue, double minZoom, double maxZoom)
    {
        if (maxZoom <= minZoom)
        {
            return minZoom;
        }

        var normalized = Clamp(sliderValue / ZoomRangeSliderMax, 0d, 1d);
        return minZoom + ((maxZoom - minZoom) * normalized);
    }

    private static bool TryReadDouble(object? value, out double result) =>
        double.TryParse(
            value?.ToString() ?? string.Empty,
            NumberStyles.Float,
            CultureInfo.InvariantCulture,
            out result);

    private static bool TryReadBool(object? value, out bool result)
    {
        if (value is bool boolValue)
        {
            result = boolValue;
            return true;
        }

        return bool.TryParse(value?.ToString(), out result);
    }

    private static double Clamp(double value, double min, double max) =>
        value < min ? min : value > max ? max : value;

    private IEnumerable<MapPinResponseDto> GetVisiblePins()
    {
        if (_layers.Count == 0)
        {
            return _pins;
        }

        var enabledLayerIds = GetLocallyVisibleLayerIds();
        return _pins.Where(pin => enabledLayerIds.Contains(pin.LayerId));
    }

    private IEnumerable<MapFeatureDto> GetVisibleFeatures()
    {
        if (_layers.Count == 0)
        {
            return _features;
        }

        var enabledLayerIds = GetLocallyVisibleLayerIds();
        return _features.Where(feature => enabledLayerIds.Contains(feature.LayerId));
    }

    private HashSet<Guid> GetEffectivelyVisibleLayerIds() =>
        MapLayerVisibilityEvaluator.GetEffectivelyVisibleLayerIds(_layers);

    private HashSet<Guid> GetLocallyVisibleLayerIds()
    {
        var visibleLayerIds = GetEffectivelyVisibleLayerIds();
        if (!TargetFeatureId.HasValue)
        {
            return visibleLayerIds;
        }

        var targetFeature = _features.FirstOrDefault(feature => feature.FeatureId == TargetFeatureId.Value);
        if (targetFeature is null)
        {
            return visibleLayerIds;
        }

        var layersById = _layers.ToDictionary(layer => layer.MapLayerId);
        var currentLayerId = targetFeature.LayerId;
        while (layersById.TryGetValue(currentLayerId, out var layer))
        {
            visibleLayerIds.Add(currentLayerId);
            if (!layer.ParentLayerId.HasValue || layer.ParentLayerId == currentLayerId)
            {
                break;
            }

            currentLayerId = layer.ParentLayerId.Value;
        }

        return visibleLayerIds;
    }

    private static string GetLayerRowClass(MapLayerDto layer, IReadOnlySet<Guid> effectivelyVisibleLayerIds) =>
        effectivelyVisibleLayerIds.Contains(layer.MapLayerId)
            ? "session-map-viewer-modal__layer-row"
            : "session-map-viewer-modal__layer-row session-map-viewer-modal__layer-row--disabled";

    private RenderFragment RenderLayerTreeItem(LayerTreeNode layerTreeNode, IReadOnlySet<Guid> effectivelyVisibleLayerIds) => @<MudTreeViewItem T="Guid"
        Value="@layerTreeNode.Layer.MapLayerId"
        class="session-map-viewer-modal__layer-tree-item"
        CanExpand="@layerTreeNode.HasChildren"
        Expanded="@layerTreeNode.IsExpanded"
        ExpandedChanged="@((bool expanded) => layerTreeNode.IsExpanded = expanded)"
        Style="padding:0px !important; margin:0px !important;">
        <BodyContent>
            <div class="@GetLayerRowClass(layerTreeNode.Layer, effectivelyVisibleLayerIds)"
                 data-layer-id="@layerTreeNode.Layer.MapLayerId"
                 data-layer-depth="@layerTreeNode.Depth">
                <input type="checkbox"
                       class="session-map-viewer-modal__layer-toggle"
                       checked="@layerTreeNode.Layer.IsEnabled"
                       @onchange="@(args => OnLayerToggleChangedAsync(layerTreeNode.Layer.MapLayerId, args))"
                       @onclick:stopPropagation="true" />
                <span class="session-map-viewer-modal__layer-name">@layerTreeNode.Layer.Name</span>
            </div>
        </BodyContent>
        <ChildContent>
            @foreach (var childLayerTreeNode in layerTreeNode.Children)
            {
                @RenderLayerTreeItem(childLayerTreeNode, effectivelyVisibleLayerIds)
            }
        </ChildContent>
    </MudTreeViewItem>;

    private List<LayerTreeNode> BuildLayerTreeRoots()
    {
        if (_layers.Count == 0)
        {
            return [];
        }

        var treeRoots = new List<LayerTreeNode>();
        var childrenByParentId = _layers
            .Where(layer => layer.ParentLayerId.HasValue && layer.ParentLayerId.Value != layer.MapLayerId)
            .GroupBy(layer => layer.ParentLayerId!.Value)
            .ToDictionary(
                group => group.Key,
                group => OrderSiblingLayers(group).ToList());

        var visited = new HashSet<Guid>();
        foreach (var rootLayer in OrderSiblingLayers(_layers.Where(IsRootLayer)))
        {
            treeRoots.Add(BuildLayerTreeDepthFirst(rootLayer, depth: 0, childrenByParentId, visited));
        }

        foreach (var remainingLayer in OrderSiblingLayers(_layers.Where(layer => !visited.Contains(layer.MapLayerId))))
        {
            treeRoots.Add(BuildLayerTreeDepthFirst(remainingLayer, depth: 0, childrenByParentId, visited));
        }

        return treeRoots;
    }

    private LayerTreeNode BuildLayerTreeDepthFirst(
        MapLayerDto layer,
        int depth,
        IReadOnlyDictionary<Guid, List<MapLayerDto>> childrenByParentId,
        ISet<Guid> visited)
    {
        var layerTreeNode = new LayerTreeNode(layer, depth);
        if (!visited.Add(layer.MapLayerId))
        {
            return layerTreeNode;
        }

        if (!childrenByParentId.TryGetValue(layer.MapLayerId, out var children) || children.Count == 0)
        {
            return layerTreeNode;
        }

        foreach (var child in children)
        {
            if (visited.Contains(child.MapLayerId))
            {
                continue;
            }

            layerTreeNode.Children.Add(BuildLayerTreeDepthFirst(child, depth + 1, childrenByParentId, visited));
        }

        return layerTreeNode;
    }

    private bool IsRootLayer(MapLayerDto layer) =>
        !layer.ParentLayerId.HasValue || !_layers.Any(candidate => candidate.MapLayerId == layer.ParentLayerId.Value);

    private static IOrderedEnumerable<MapLayerDto> OrderSiblingLayers(IEnumerable<MapLayerDto> layers) =>
        layers
            .OrderBy(layer => layer.SortOrder)
            .ThenBy(layer => layer.Name, StringComparer.Ordinal)
            .ThenBy(layer => layer.MapLayerId);

    private async Task<IJSObjectReference?> EnsureModuleAsync()
    {
        if (_mapInteropModule != null) return _mapInteropModule;
        try
        {
            _mapInteropModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/mapPageInterop.js?v=3");
            return _mapInteropModule;
        }
        catch (JSException)
        {
            return null;
        }
    }

    private async Task<MapElementRect?> GetElementRectAsync(ElementReference elementRef)
    {
        var module = await EnsureModuleAsync();
        if (module == null)
            return await JSRuntime.InvokeAsync<MapElementRect?>("chronicisMapPage.getElementRect", elementRef);

        try
        {
            var rect = await module.InvokeAsync<MapElementRect?>("getElementRect", elementRef);
            if (HasUsableBounds(rect)) return rect;
        }
        catch (JSException) { }

        return await JSRuntime.InvokeAsync<MapElementRect?>("chronicisMapPage.getElementRect", elementRef);
    }

    private void ResetMapViewportState()
    {
        _hasMapViewportLayout = false;
        _mapBaseWidth = 0d;
        _mapBaseHeight = 0d;
        _mapViewportWidth = 0d;
        _mapViewportHeight = 0d;
        _mapMinZoom = 1d;
        _mapMaxZoom = 1d;
        _mapZoom = 1d;
        _mapPanX = 0d;
        _mapPanY = 0d;
        _isMapPointerDown = false;
        _isMapDragging = false;
        _dragStartClientX = 0d;
        _dragStartClientY = 0d;
        _dragStartPanX = 0d;
        _dragStartPanY = 0d;
    }

    private static bool HasUsableBounds(MapElementRect? rect) =>
        rect != null && rect.Width > 0d && rect.Height > 0d;

    private void FocusTargetFeatureIfNeeded()
    {
        if (!_targetFocusPending || !TargetFeatureId.HasValue || !_hasMapViewportLayout)
        {
            return;
        }

        var targetFeature = _features.FirstOrDefault(feature => feature.FeatureId == TargetFeatureId.Value);
        if (targetFeature is null || !TryGetFeatureCenter(targetFeature, out var centerX, out var centerY))
        {
            _targetFocusPending = false;
            _highlightedFeatureId = null;
            return;
        }

        _highlightedFeatureId = targetFeature.FeatureId;
        _targetFocusPending = false;

        var nextZoom = Clamp(_mapMinZoom * 2d, _mapMinZoom, _mapMaxZoom);
        _mapZoom = nextZoom;
        _mapPanX = (_mapViewportWidth / 2d) - ((centerX * _mapBaseWidth) * _mapZoom);
        _mapPanY = (_mapViewportHeight / 2d) - ((centerY * _mapBaseHeight) * _mapZoom);
        ClampPanToBounds();
    }

    private static bool TryGetFeatureCenter(MapFeatureDto feature, out double x, out double y)
    {
        if (feature.Point is not null)
        {
            x = feature.Point.X;
            y = feature.Point.Y;
            return true;
        }

        if (feature.Polygon?.Coordinates?.Count > 0 && feature.Polygon.Coordinates[0].Count > 0)
        {
            var ring = feature.Polygon.Coordinates[0];
            var usablePoints = ring.Count > 1 && ring[0][0] == ring[^1][0] && ring[0][1] == ring[^1][1]
                ? ring.Take(ring.Count - 1).ToList()
                : ring;

            x = usablePoints.Average(point => point[0]);
            y = usablePoints.Average(point => point[1]);
            return true;
        }

        x = 0d;
        y = 0d;
        return false;
    }

