    }

    private async Task CloseAsync()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }

    private Task HandleKeyDown(KeyboardEventArgs args) =>
        string.Equals(args.Key, "Escape", StringComparison.Ordinal)
            ? CloseAsync()
            : Task.CompletedTask;

    private string ViewerTitle =>
        string.IsNullOrWhiteSpace(MapName) ? "Map" : MapName.Trim();

    private bool IsPublicMode => !string.IsNullOrWhiteSpace(PublicSlug);

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_mapInteropModule != null)
            {
                await _mapInteropModule.InvokeVoidAsync("teardownWheelInterceptor", _mapViewportRef);
                await _mapInteropModule.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        _dotNetRef?.Dispose();
    }

    private static bool IsUnauthorized(int? statusCode) => statusCode == 401 || statusCode == 403;

    private static bool IsBasemapMissing(int? statusCode, string? error)
    {
        if (statusCode != 404 || string.IsNullOrWhiteSpace(error))
        {
            return false;
        }

        return error.Contains("basemap", StringComparison.OrdinalIgnoreCase);
    }

    private enum SessionMapViewerState
    {
        None,
        Loaded,
        Unauthorized,
        NotFound,
        BasemapMissing
    }

    private sealed class LayerTreeNode(MapLayerDto layer, int depth)
    {
        public MapLayerDto Layer { get; } = layer;

        public int Depth { get; } = depth;

        public bool IsExpanded { get; set; } = true;

        public List<LayerTreeNode> Children { get; } = [];

        public bool HasChildren => Children.Count > 0;
    }
